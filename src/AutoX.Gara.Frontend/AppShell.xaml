<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AutoX.Gara.Frontend.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AutoX.Gara.Frontend.Views"
    Title="AutoX.Gara">

    <ShellContent
        Title="Đăng nhập"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />
    
    <ShellContent
        Title="Trang chủ"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <ShellContent 
        Title="Khách hàng"
        ContentTemplate="{DataTemplate views:CustomersPage}"
        Route="CustomersPage" />

    <ShellContent 
        Title="Nhà cung cấp"
        ContentTemplate="{DataTemplate views:SuppliersPage}"
        Route="SuppliersPage" />

    <ShellContent 
        Title="Kho hàng"
        ContentTemplate="{DataTemplate views:PartsPage}"
        Route="SparePartsPage" />
</Shell>
