<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AutoX.Gara.Frontend.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AutoX.Gara.Frontend.Views"
    Title="AutoX.Gara">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />
    
    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate views:MainPage}"
        Route="MainPage" />

    <ShellContent 
        Title="Customers"
        ContentTemplate="{DataTemplate views:CustomersPage}"
        Route="CustomersPage" />

    <ShellContent 
        Title="Spare parts"
        ContentTemplate="{DataTemplate views:SparePartsPage}"
        Route="SparePartsPage" />

    <ShellContent 
        Title="Replacement parts"
        ContentTemplate="{DataTemplate views:ReplacementPartsPage}"
        Route="ReplacementPartsPage" />
</Shell>
