<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Shell.NavBarIsVisible="False"
             Shell.FlyoutBehavior="Disabled"
             x:Class="AutoX.Gara.Frontend.LoginPage"
             Title="Login">

    <Grid>
        <VerticalStackLayout Spacing="16" Margin="30">

            <Image Source="car.png"
               HeightRequest="60"
               HorizontalOptions="Center"
               Margin="0,0,0,6"/>

            <Label Text="MMK Login"
               FontAttributes="Bold"
               FontSize="20"
               HorizontalOptions="Center"
               TextColor="White"/>

            <Grid HeightRequest="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>
                <!-- Cột 0 trống -->
                <Entry Grid.Column="1"
                   Placeholder="Username"
                   Text="{Binding Username}"
                   FontSize="16"
                   HeightRequest="48"
                   BackgroundColor="#222"
                   TextColor="White"
                   Margin="0"/>
                <!-- Cột 2 trống luôn -->
            </Grid>

            <!-- Password row: icon mắt ở cột 0 -->
            <Grid HeightRequest="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32"/>
                </Grid.ColumnDefinitions>
                <!-- Cột 0: trống luôn -->
                <!-- Cột 1: Entry password -->
                <Entry Grid.Column="1"
                   Placeholder="Password"
                   IsPassword="{Binding IsPasswordHidden}"
                   Text="{Binding Password}"
                   FontSize="16"
                   HeightRequest="48"
                   BackgroundColor="#222"
                   TextColor="White"
                   Margin="0"/>
                <!-- Cột 2: icon mắt -->
                <Image Grid.Column="2"
                   Source="{Binding PasswordIcon}"
                   WidthRequest="24"
                   HeightRequest="24"
                   VerticalOptions="Center"
                   HorizontalOptions="Center">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TogglePasswordCommand}" />
                    </Image.GestureRecognizers>
                </Image>
            </Grid>

            <!-- Login button -->
            <Button Text="Login"
                Command="{Binding LoginCommand}" 
                HeightRequest="46"
                CornerRadius="12"
                FontAttributes="Bold"
                BackgroundColor="#3182ce"
                TextColor="White"
                FontSize="16"
                Margin="32,16,32,8"/>

            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="12"
                   IsVisible="{Binding HasError}"
                   HorizontalOptions="Start"/>
            
        </VerticalStackLayout>

        <!-- Popup overlay -->
        <Grid IsVisible="{Binding IsPopupVisible}"
              BackgroundColor="#80000000"
              ZIndex="100">
            <Border Padding="24"
                   BackgroundColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   WidthRequest="340">
                <VerticalStackLayout Spacing="16">
                    <Label Text="{Binding PopupTitle}" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="Black"/>
                    
                    <Label Text="{Binding PopupMessage}" 
                           FontSize="15" 
                           TextColor="Black"/>
                    
                    <Button Text="{Binding PopupButtonText}" 
                            Command="{Binding ClosePopupCommand}"
                            Margin="0"
                            FontSize="15" 
                            TextColor="#3182ce"
                            BackgroundColor="Transparent"
                            HorizontalOptions="End"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Loading overlay -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="#80000000"
              ZIndex="10">
            <ActivityIndicator IsRunning="True"
                               IsVisible="True"
                               Color="White"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               WidthRequest="40"
                               HeightRequest="40"/>
        </Grid>
        
    </Grid>
</ContentPage>