<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AutoX.Gara.Frontend.ViewModels"
             xmlns:genderEnums="clr-namespace:AutoX.Gara.Domain.Enums;assembly=AutoX.Gara.Domain"
             xmlns:dto="clr-namespace:AutoX.Gara.Shared.Packets.Customers;assembly=AutoX.Gara.Shared"
             xmlns:enums="clr-namespace:AutoX.Gara.Domain.Enums.Customers;assembly=AutoX.Gara.Domain"
             x:DataType="vm:CustomersViewModel"
             x:Class="AutoX.Gara.Frontend.CustomersPage"
             Title="Khách hàng"
             BackgroundColor="#0f0f0f">

    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════════
             MAIN LAYOUT
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
              Margin="20,16">

            <!-- ── Row 0: Header ────────────────────────────────────────────── -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Margin="0,0,0,16">

                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Quản lý khách hàng"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{Binding TotalCount, StringFormat='Tổng: {0} khách hàng'}"
                           FontSize="12"
                           TextColor="#888"/>
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="+ Thêm khách hàng"
                        Command="{Binding OpenCreateFormCommand}"
                        BackgroundColor="#2563eb"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="42"
                        Padding="16,0"/>
            </Grid>

            <!-- ── Row 1: Search + Sort bar ─────────────────────────────────── -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                  ColumnSpacing="8"
                  Margin="0,0,0,8">

                <!-- Search box -->
                <Border Grid.Column="0"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="42">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          Padding="12,0">
                        <Label Grid.Column="0"
                               Text="🔍"
                               FontSize="14"
                               VerticalOptions="Center"
                               Margin="0,0,8,0"/>
                        <Entry Grid.Column="1"
                               Placeholder="Tìm theo tên, email, SĐT, ghi chú..."
                               PlaceholderColor="#555"
                               Text="{Binding SearchTerm}"
                               TextColor="White"
                               FontSize="14"
                               BackgroundColor="Transparent"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2"
                               Text="✕"
                               FontSize="13"
                               TextColor="#666"
                               VerticalOptions="Center"
                               IsVisible="{Binding SearchTerm, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearSearchCommand}"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Sort: Tên -->
                <Border Grid.Column="1"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="42"
                        WidthRequest="90">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SortByColumnCommand}"
                                              CommandParameter="Name"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="4">
                        <Label Text="Tên" FontSize="13" TextColor="#aaa" VerticalOptions="Center"/>
                        <Label Text="↕" FontSize="11" TextColor="#555" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Sort: Email -->
                <Border Grid.Column="2"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="42"
                        WidthRequest="90">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SortByColumnCommand}"
                                              CommandParameter="Email"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="4">
                        <Label Text="Email" FontSize="13" TextColor="#aaa" VerticalOptions="Center"/>
                        <Label Text="↕" FontSize="11" TextColor="#555" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Sort: Ngày tạo -->
                <Border Grid.Column="3"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="42"
                        WidthRequest="100">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SortByColumnCommand}"
                                              CommandParameter="CreatedAt"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="4">
                        <Label Text="Ngày tạo" FontSize="13" TextColor="#aaa" VerticalOptions="Center"/>
                        <Label Text="↕" FontSize="11" TextColor="#555" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Refresh -->
                <Border Grid.Column="4"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="42"
                        WidthRequest="42">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LoadCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="↻"
                           FontSize="18"
                           TextColor="#aaa"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- ── Row 2: Filter bar ─────────────────────────────────────────── -->
            <Grid Grid.Row="2"
                  ColumnDefinitions="Auto,Auto,Auto,*,Auto"
                  ColumnSpacing="8"
                  Margin="0,0,0,12">

                <!-- Label -->
                <Label Grid.Column="0"
                       Text="Lọc:"
                       FontSize="13"
                       TextColor="#666"
                       VerticalOptions="Center"/>

                <!-- Filter: CustomerType -->
                <Border Grid.Column="1"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="36"
                        MinimumWidthRequest="130">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Picker x:Name="TypeFilterPicker"
                            Title="Loại khách hàng"
                            TitleColor="#555"
                            TextColor="#aaa"
                            FontSize="13"
                            BackgroundColor="Transparent"
                            SelectedItem="{Binding FilterType}"
                            Margin="10,0">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type enums:CustomerType}">
                                <enums:CustomerType>None</enums:CustomerType>
                                <enums:CustomerType>Individual</enums:CustomerType>
                                <enums:CustomerType>Business</enums:CustomerType>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>

                <!-- Filter: MembershipLevel -->
                <Border Grid.Column="2"
                        BackgroundColor="#1a1a1a"
                        StrokeThickness="1"
                        Stroke="#2d2d2d"
                        HeightRequest="36"
                        MinimumWidthRequest="130">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Picker Title="Hạng thành viên"
                            TitleColor="#555"
                            TextColor="#aaa"
                            FontSize="13"
                            BackgroundColor="Transparent"
                            SelectedItem="{Binding FilterMembership}"
                            Margin="10,0">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type enums:MembershipLevel}">
                                <enums:MembershipLevel>None</enums:MembershipLevel>
                                <enums:MembershipLevel>Trial</enums:MembershipLevel>
                                <enums:MembershipLevel>Standard</enums:MembershipLevel>
                                <enums:MembershipLevel>Silver</enums:MembershipLevel>
                                <enums:MembershipLevel>Gold</enums:MembershipLevel>
                                <enums:MembershipLevel>Platinum</enums:MembershipLevel>
                                <enums:MembershipLevel>Diamond</enums:MembershipLevel>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </Border>

                <!-- Spacer -->
                <BoxView Grid.Column="3" Color="Transparent"/>

                <!-- Clear filters button — chỉ hiện khi có filter active -->
                <Border Grid.Column="4"
                        BackgroundColor="#2d1a1a"
                        StrokeThickness="1"
                        Stroke="#7f1d1d"
                        HeightRequest="36"
                        Padding="10,0"
                        IsVisible="{Binding HasActiveFilters}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ClearFiltersCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="✕ Xóa filter"
                           FontSize="12"
                           TextColor="#fca5a5"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- ── Row 3: Customer list ──────────────────────────────────────── -->
            <Grid Grid.Row="3">

                <!-- Inline error banner -->
                <Border BackgroundColor="#2d1a1a"
                        StrokeThickness="1"
                        Stroke="#7f1d1d"
                        Padding="14,10"
                        IsVisible="{Binding HasError}"
                        VerticalOptions="Start"
                        ZIndex="5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding ErrorMessage}"
                           TextColor="#fca5a5"
                           FontSize="13"/>
                </Border>

                <!-- Empty state -->
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     IsVisible="{Binding IsEmpty}">
                    <Label Text="👤"
                           FontSize="40"
                           HorizontalOptions="Center"/>
                    <Label Text="Chưa có khách hàng nào"
                           FontSize="15"
                           TextColor="#555"
                           HorizontalOptions="Center"/>
                    <Label Text="Nhấn '+ Thêm khách hàng' để bắt đầu"
                           FontSize="12"
                           TextColor="#444"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Customer list -->
                <CollectionView ItemsSource="{Binding Customers}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:CustomerDataPacket">
                            <Border BackgroundColor="#141414"
                                    StrokeThickness="1"
                                    Stroke="#222"
                                    Padding="16,14">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*,Auto,Auto"
                                      ColumnSpacing="14">

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="3"
                                                         VerticalOptions="Center">
                                        <!-- Tên + Gender icon -->
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   LineBreakMode="TailTruncation"
                                                   VerticalOptions="Center"/>
                                            <!-- Gender badge -->
                                            <Label Text="{Binding Gender, Converter={StaticResource GenderToIconConverter}}"
                                                   FontSize="12"
                                                   TextColor="#666"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <!-- Email + SĐT -->
                                        <HorizontalStackLayout Spacing="12">
                                            <Label Text="{Binding Email}"
                                                   FontSize="12"
                                                   TextColor="#888"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding PhoneNumber}"
                                                   FontSize="12"
                                                   TextColor="#666"/>
                                        </HorizontalStackLayout>

                                        <!-- Badges row: Membership + Type -->
                                        <HorizontalStackLayout Spacing="6" Margin="0,2,0,0">
                                            <Border BackgroundColor="#1c2a1c"
                                                    StrokeThickness="0"
                                                    Padding="6,2">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="4"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Membership}"
                                                       FontSize="10"
                                                       TextColor="#86efac"/>
                                            </Border>
                                            <Border BackgroundColor="#1a1f2e"
                                                    StrokeThickness="0"
                                                    Padding="6,2">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="4"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Type}"
                                                       FontSize="10"
                                                       TextColor="#93c5fd"/>
                                            </Border>
                                        </HorizontalStackLayout>

                                        <!-- Notes preview — chỉ hiện khi có ghi chú -->
                                        <Label Text="{Binding Notes}"
                                               FontSize="11"
                                               TextColor="#4a4a4a"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"
                                               Margin="0,2,0,0"
                                               IsVisible="{Binding Notes, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
                                    </VerticalStackLayout>

                                    <!-- Edit button -->
                                    <Border Grid.Column="1"
                                            BackgroundColor="#1a2a3a"
                                            StrokeThickness="0"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomersViewModel}}, Path=OpenEditFormCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="✏"
                                               FontSize="15"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Delete button -->
                                    <Border Grid.Column="2"
                                            BackgroundColor="#2d1a1a"
                                            StrokeThickness="0"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="8"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CustomersViewModel}}, Path=RequestDeleteCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="🗑"
                                               FontSize="15"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- ── Row 4: Pagination ─────────────────────────────────────────── -->
            <Grid Grid.Row="4"
                  ColumnDefinitions="Auto,*,Auto"
                  Margin="0,12,0,0">

                <Button Grid.Column="0"
                        Text="← Trước"
                        Command="{Binding PreviousPageCommand}"
                        IsVisible="{Binding HasPreviousPage}"
                        BackgroundColor="#1a1a1a"
                        TextColor="#aaa"
                        FontSize="13"
                        CornerRadius="8"
                        HeightRequest="38"
                        Padding="14,0"/>

                <Label Grid.Column="1"
                       Text="{Binding CurrentPage, StringFormat='Trang {0}'}"
                       FontSize="13"
                       TextColor="#555"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>

                <Button Grid.Column="2"
                        Text="Tiếp →"
                        Command="{Binding NextPageCommand}"
                        IsVisible="{Binding HasNextPage}"
                        BackgroundColor="#1a1a1a"
                        TextColor="#aaa"
                        FontSize="13"
                        CornerRadius="8"
                        HeightRequest="38"
                        Padding="14,0"/>
            </Grid>

        </Grid>
        <!-- end main grid -->


        <!-- ═══════════════════════════════════════════════════════════════════
             FORM OVERLAY (Create / Edit)
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsFormVisible}"
              BackgroundColor="#b3000000"
              ZIndex="50">
            <Border Padding="28,24"
                    BackgroundColor="#161616"
                    StrokeThickness="1"
                    Stroke="#2d2d2d"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="520">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>

                <ScrollView MaximumHeightRequest="700">
                    <VerticalStackLayout Spacing="0">

                        <!-- Form header -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                            <Label Grid.Column="0"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="IsEditing"
                                                 Converter="{StaticResource BoolToStringConverter}"
                                                 ConverterParameter="Chỉnh sửa khách hàng|Thêm khách hàng mới"/>
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Grid.Column="1"
                                   Text="✕"
                                   FontSize="18"
                                   TextColor="#555"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CloseFormCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Form error -->
                        <Border BackgroundColor="#2d1a1a"
                                StrokeThickness="1"
                                Stroke="#7f1d1d"
                                Padding="12,8"
                                Margin="0,0,0,14"
                                IsVisible="{Binding HasFormError}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Label Text="{Binding FormErrorMessage}"
                                   TextColor="#fca5a5"
                                   FontSize="13"/>
                        </Border>

                        <!-- ── Họ và tên ────────────────────────────────── -->
                        <Label Text="Họ và tên *" FontSize="12" TextColor="#aaa" Margin="0,0,0,6"/>
                        <Border BackgroundColor="#1a1a1a"
                                StrokeThickness="1" Stroke="#2d2d2d"
                                HeightRequest="46" Margin="0,0,0,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Entry Placeholder="Nhập họ và tên"
                                   PlaceholderColor="#555"
                                   Text="{Binding FormName}"
                                   TextColor="White" FontSize="14"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center" ReturnType="Next"/>
                        </Border>

                        <!-- ── Email + SĐT (2 cột) ─────────────────────── -->
                        <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,14">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Email *" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry Placeholder="example@email.com"
                                           PlaceholderColor="#555"
                                           Text="{Binding FormEmail}"
                                           TextColor="White" FontSize="14"
                                           Keyboard="Email"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center" ReturnType="Next"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Label Text="Số điện thoại *" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry Placeholder="0901234567"
                                           PlaceholderColor="#555"
                                           Text="{Binding FormPhone}"
                                           TextColor="White" FontSize="14"
                                           Keyboard="Telephone"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center" ReturnType="Next"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- ── Loại KH + Hạng thành viên (2 cột) ─────────── -->
                        <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,14">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Loại khách hàng" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Picker SelectedItem="{Binding FormType}"
                                            TextColor="#aaa" FontSize="14"
                                            BackgroundColor="Transparent"
                                            TitleColor="#555" Margin="10,0">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type enums:CustomerType}">
                                                <enums:CustomerType>None</enums:CustomerType>
                                                <enums:CustomerType>Individual</enums:CustomerType>
                                                <enums:CustomerType>Business</enums:CustomerType>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Label Text="Hạng thành viên" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Picker SelectedItem="{Binding FormMembership}"
                                            TextColor="#aaa" FontSize="14"
                                            BackgroundColor="Transparent"
                                            TitleColor="#555" Margin="10,0">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type enums:MembershipLevel}">
                                                <enums:MembershipLevel>None</enums:MembershipLevel>
                                                <enums:MembershipLevel>Trial</enums:MembershipLevel>
                                                <enums:MembershipLevel>Standard</enums:MembershipLevel>
                                                <enums:MembershipLevel>Silver</enums:MembershipLevel>
                                                <enums:MembershipLevel>Gold</enums:MembershipLevel>
                                                <enums:MembershipLevel>Platinum</enums:MembershipLevel>
                                                <enums:MembershipLevel>Diamond</enums:MembershipLevel>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- ── Giới tính + Ngày sinh (2 cột) ─────────────── -->
                        <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,14">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Giới tính" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Picker SelectedItem="{Binding FormGender}"
                                            TextColor="#aaa" FontSize="14"
                                            BackgroundColor="Transparent"
                                            TitleColor="#555" Margin="10,0">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type genderEnums:Gender}">
                                                <genderEnums:Gender>None</genderEnums:Gender>
                                                <genderEnums:Gender>Male</genderEnums:Gender>
                                                <genderEnums:Gender>Female</genderEnums:Gender>-
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Label Text="Ngày sinh" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <DatePicker Date="{Binding FormDateOfBirth, TargetNullValue={x:Static sys:DateTime.Today}}"
                                                TextColor="#aaa"
                                                FontSize="14"
                                                BackgroundColor="Transparent"
                                                Format="dd/MM/yyyy"
                                                Margin="10,0"
                                                VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- ── Địa chỉ + Mã số thuế (2 cột) ─────────────── -->
                        <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,14">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="Địa chỉ" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry Placeholder="Địa chỉ"
                                           PlaceholderColor="#555"
                                           Text="{Binding FormAddress}"
                                           TextColor="White" FontSize="14"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Label Text="Mã số thuế" FontSize="12" TextColor="#aaa"/>
                                <Border BackgroundColor="#1a1a1a"
                                        StrokeThickness="1" Stroke="#2d2d2d" HeightRequest="46">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="10"/>
                                    </Border.StrokeShape>
                                    <Entry Placeholder="MST (nếu có)"
                                           PlaceholderColor="#555"
                                           Text="{Binding FormTaxCode}"
                                           TextColor="White" FontSize="14"
                                           BackgroundColor="Transparent"
                                           VerticalOptions="Center"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- ── Ghi chú nội bộ ─────────────────────────────── -->
                        <Label FontSize="12" TextColor="#aaa" Margin="0,0,0,6">
                            <Label.Text>
                                <MultiBinding StringFormat="Ghi chú nội bộ ({0}/500)">
                                    <Binding Path="FormNotes.Length"/>
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Border BackgroundColor="#1a1a1a"
                                StrokeThickness="1" Stroke="#2d2d2d"
                                HeightRequest="90" Margin="0,0,0,20">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Editor Placeholder="Ghi chú nội bộ về khách hàng (không hiển thị cho khách)..."
                                    PlaceholderColor="#555"
                                    Text="{Binding FormNotes}"
                                    TextColor="White" FontSize="14"
                                    BackgroundColor="Transparent"
                                    AutoSize="TextChanges"
                                    MaxLength="500"
                                    Margin="10,8"/>
                        </Border>

                        <!-- ── Action buttons ──────────────────────────────── -->
                        <Grid ColumnDefinitions="*,12,*">
                            <Button Grid.Column="0"
                                    Text="Hủy"
                                    Command="{Binding CloseFormCommand}"
                                    BackgroundColor="#1e1e1e"
                                    TextColor="#aaa"
                                    FontSize="14"
                                    CornerRadius="10"
                                    HeightRequest="46"
                                    BorderColor="#2d2d2d"
                                    BorderWidth="1"/>
                            <Button Grid.Column="2"
                                    Command="{Binding SaveFormCommand}"
                                    BackgroundColor="#2563eb"
                                    TextColor="White"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    CornerRadius="10"
                                    HeightRequest="46">
                                <Button.Text>
                                    <MultiBinding StringFormat="{}{0}">
                                        <Binding Path="IsEditing"
                                                 Converter="{StaticResource BoolToStringConverter}"
                                                 ConverterParameter="Lưu thay đổi|Tạo khách hàng"/>
                                    </MultiBinding>
                                </Button.Text>
                            </Button>
                        </Grid>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>


        <!-- ═══════════════════════════════════════════════════════════════════
             DELETE CONFIRM POPUP
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsDeleteConfirmVisible}"
              BackgroundColor="#b3000000"
              ZIndex="60">
            <Border Padding="28,24"
                    BackgroundColor="#1e1e1e"
                    StrokeThickness="1"
                    Stroke="#333"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="340">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Xác nhận xóa"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label FontSize="14" TextColor="#bbb" LineBreakMode="WordWrap">
                        <Label.Text>
                            <MultiBinding StringFormat="Bạn có chắc muốn xóa khách hàng '{0}'?&#x0a;Dữ liệu sẽ được ẩn nhưng vẫn được lưu trữ.">
                                <Binding Path="SelectedCustomer.Name"/>
                            </MultiBinding>
                        </Label.Text>
                    </Label>
                    <Grid ColumnDefinitions="*,10,*" Margin="0,8,0,0">
                        <Button Grid.Column="0"
                                Text="Hủy"
                                Command="{Binding CancelDeleteCommand}"
                                BackgroundColor="Transparent"
                                TextColor="#aaa" FontSize="14"
                                CornerRadius="8" HeightRequest="40"
                                BorderColor="#333" BorderWidth="1"/>
                        <Button Grid.Column="2"
                                Text="Xóa"
                                Command="{Binding ConfirmDeleteCommand}"
                                BackgroundColor="#dc2626"
                                TextColor="White" FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="8" HeightRequest="40"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>


        <!-- ═══════════════════════════════════════════════════════════════════
             ERROR / INFO POPUP
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsPopupVisible}"
              BackgroundColor="#99000000"
              ZIndex="70">
            <Border Padding="28,24"
                    BackgroundColor="#1e1e1e"
                    StrokeThickness="1"
                    Stroke="#333"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    WidthRequest="320">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding PopupTitle}"
                           FontSize="17" FontAttributes="Bold" TextColor="White"/>
                    <Label Text="{Binding PopupMessage}"
                           FontSize="14" TextColor="#bbb" LineBreakMode="WordWrap"/>
                    <Grid Margin="0,8,0,0" ColumnDefinitions="*,Auto">
                        <Button Grid.Column="1"
                                Text="{Binding PopupButtonText}"
                                Command="{Binding RetryLoadCommand}"
                                IsVisible="{Binding IsPopupRetry}"
                                BackgroundColor="#2563eb" TextColor="White"
                                CornerRadius="8" Padding="20,0"
                                HeightRequest="38" FontSize="14"/>
                        <Button Grid.Column="1"
                                Text="OK"
                                Command="{Binding ClosePopupCommand}"
                                IsVisible="{Binding IsPopupNotRetry}"
                                BackgroundColor="Transparent" TextColor="#2563eb"
                                CornerRadius="8" Padding="20,0"
                                HeightRequest="38" FontSize="14"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>


        <!-- ═══════════════════════════════════════════════════════════════════
             LOADING OVERLAY
             ═══════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsLoading}"
              BackgroundColor="#99000000"
              ZIndex="100">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="14">
                <ActivityIndicator IsRunning="True"
                                   Color="White"
                                   WidthRequest="36"
                                   HeightRequest="36"
                                   HorizontalOptions="Center"/>
                <Label Text="Đang tải..."
                       TextColor="#ccc" FontSize="13"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

    </Grid>
    <!-- end root grid -->
</ContentPage>
