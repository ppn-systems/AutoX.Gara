<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AutoX.Gara.UI.ViewModels"
    x:Class="AutoX.Gara.Frontend.Views.LoginPage"
    x:DataType="vm:LoginViewModel"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBehavior="Disabled"
    Title="Login"
    BackgroundColor="#0f0f0f">

    <Grid>
        <Grid HorizontalOptions="Center" WidthRequest="400" HeightRequest="520">
            <VerticalStackLayout Spacing="0" VerticalOptions="Center" Margin="48,0">
                <Image
                    Source="car.png"
                    HeightRequest="72"
                    HorizontalOptions="Center"
                    Margin="0,0,0,20" />

                <Label
                    Text="{Binding AppTitleText}"
                    FontAttributes="Bold"
                    FontSize="26"
                    HorizontalOptions="Center"
                    TextColor="White"
                    Margin="0,0,0,4" />

                <Label
                    Text="{Binding AppSubtitleText}"
                    FontSize="13"
                    HorizontalOptions="Center"
                    TextColor="#888"
                    Margin="0,0,0,36" />

                <Label
                    Text="{Binding UsernameLabelText}"
                    FontSize="12"
                    TextColor="#aaa"
                    Margin="0,0,0,6" />

                <Border
                    BackgroundColor="#1a1a1a"
                    StrokeThickness="1"
                    Stroke="#2d2d2d"
                    HeightRequest="48"
                    Margin="0,0,0,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Entry
                        Placeholder="{Binding UsernamePlaceholderText}"
                        PlaceholderColor="#555"
                        Text="{Binding Username}"
                        TextColor="White"
                        FontSize="15"
                        BackgroundColor="Transparent"
                        Margin="0,0,32,0"
                        VerticalOptions="Center"
                        ReturnType="Next" />
                </Border>

                <Label
                    Text="{Binding PasswordLabelText}"
                    FontSize="12"
                    TextColor="#aaa"
                    Margin="0,0,0,6" />

                <Border
                    BackgroundColor="#1a1a1a"
                    StrokeThickness="1"
                    Stroke="#2d2d2d"
                    HeightRequest="48"
                    Margin="0,0,0,16">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="32" />
                        </Grid.ColumnDefinitions>

                        <Entry
                            Grid.Column="0"
                            Placeholder="{Binding PasswordPlaceholderText}"
                            PlaceholderColor="#555"
                            IsPassword="{Binding IsPasswordHidden}"
                            Text="{Binding Password}"
                            TextColor="White"
                            FontSize="15"
                            BackgroundColor="Transparent"
                            VerticalOptions="Center"
                            ReturnCommand="{Binding LoginCommand}" />

                        <Image
                            Grid.Column="1"
                            Source="{Binding PasswordIcon}"
                            WidthRequest="22"
                            HeightRequest="22"
                            VerticalOptions="Center"
                            HorizontalOptions="Center"
                            Opacity="0.6">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </Image.GestureRecognizers>
                        </Image>
                    </Grid>
                </Border>

                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#ff6b6b"
                    FontSize="12"
                    IsVisible="{Binding HasError}"
                    Margin="2,0,0,12" />

                <Button
                    Text="{Binding LoginButtonText}"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNetworkReady}"
                    HeightRequest="50"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    BackgroundColor="#2563eb"
                    TextColor="White"
                    FontSize="15"
                    Margin="0,8,0,0" />

                <Button
                    Text="{Binding RegisterButtonText}"
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsNetworkReady}"
                    HeightRequest="44"
                    CornerRadius="10"
                    FontAttributes="Bold"
                    BackgroundColor="Transparent"
                    BorderColor="#2d2d2d"
                    BorderWidth="1"
                    TextColor="#d4d4d8"
                    FontSize="14"
                    Margin="0,10,0,0" />

                <Label
                    Text="{Binding NetworkWarningText}"
                    FontSize="12"
                    TextColor="#f59e0b"
                    HorizontalOptions="Center"
                    Margin="0,10,0,0"
                    IsVisible="{Binding IsNetworkNotReady}" />
            </VerticalStackLayout>
        </Grid>

        <Grid
            IsVisible="{Binding IsPopupVisible}"
            BackgroundColor="#99000000"
            ZIndex="100">
            <Border
                Padding="28,24"
                BackgroundColor="#1e1e1e"
                StrokeThickness="1"
                Stroke="#333"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="320">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label
                        Text="{Binding PopupTitle}"
                        FontSize="17"
                        FontAttributes="Bold"
                        TextColor="White" />
                    <Label
                        Text="{Binding PopupMessage}"
                        FontSize="14"
                        TextColor="#bbb"
                        LineBreakMode="WordWrap" />
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="1"
                            Text="{Binding PopupButtonText}"
                            Command="{Binding RetryConnectionCommand}"
                            IsVisible="{Binding IsPopupRetry}"
                            BackgroundColor="#2563eb"
                            TextColor="White"
                            CornerRadius="8"
                            Padding="20,0"
                            HeightRequest="38"
                            FontSize="14" />

                        <Button
                            Grid.Column="1"
                            Text="{Binding PopupOkButtonText}"
                            Command="{Binding ClosePopupCommand}"
                            IsVisible="{Binding IsPopupNotRetry}"
                            BackgroundColor="Transparent"
                            TextColor="#2563eb"
                            CornerRadius="8"
                            Padding="20,0"
                            HeightRequest="38"
                            FontSize="14" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            IsVisible="{Binding IsLoading}"
            BackgroundColor="#99000000"
            ZIndex="10">
            <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="14">
                <ActivityIndicator
                    IsRunning="True"
                    Color="White"
                    WidthRequest="36"
                    HeightRequest="36"
                    HorizontalOptions="Center" />
                <Label
                    Text="{Binding LoadingText}"
                    TextColor="#ccc"
                    FontSize="13"
                    HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
