<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="PageRoot"
    x:Class="AutoX.Gara.Frontend.Views.PartsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:vm="clr-namespace:AutoX.Gara.Frontend.ViewModels"
    xmlns:pkt="clr-namespace:AutoX.Gara.Shared.Protocol.Inventory;assembly=AutoX.Gara.Shared"
    xmlns:conv="clr-namespace:AutoX.Gara.Frontend.Converters"
    Title="Quản lý phụ tùng"
    BackgroundColor="#0A0A0F">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter          x:Key="InverseBool"   />
            <conv:DecimalToCurrencyConverter    x:Key="ToCurrency"    />
            <conv:DateOnlyToStringConverter     x:Key="ToDateStr"     />
            <conv:PartCategoryToColorConverter  x:Key="CategoryColor" />
            <conv:EnumTextConverter             x:Key="EnumText"      />

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor"  Value="#111118" />
                <Setter Property="StrokeShape"      Value="RoundRectangle 10" />
                <Setter Property="Stroke"           Value="#2A2A38" />
                <Setter Property="StrokeThickness"  Value="1" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#000000" Opacity="0.25" Radius="18" Offset="0,6" />
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="InputBorder" TargetType="Border">
                <Setter Property="BackgroundColor"  Value="#1A1A24" />
                <Setter Property="StrokeShape"      Value="RoundRectangle 8" />
                <Setter Property="Stroke"           Value="#2A2A38" />
                <Setter Property="StrokeThickness"  Value="1" />
                <Setter Property="HeightRequest"    Value="44" />
            </Style>
            <Style x:Key="BadgeStyle" TargetType="Border">
                <Setter Property="StrokeShape"      Value="RoundRectangle 4" />
                <Setter Property="StrokeThickness"  Value="0" />
                <Setter Property="Padding"          Value="6,2" />
                <Setter Property="VerticalOptions"  Value="Center" />
                <Setter Property="InputTransparent" Value="True" />
            </Style>
            <Style x:Key="MutedLabel" TargetType="Label">
                <Setter Property="FontSize"        Value="13" />
                <Setter Property="TextColor"       Value="#6B6B80" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="Label">
                <Setter Property="FontSize"         Value="12" />
                <Setter Property="FontAttributes"   Value="Bold" />
                <Setter Property="TextColor"        Value="#6B6B80" />
                <Setter Property="Margin"           Value="0,12,0,5" />
                <Setter Property="CharacterSpacing" Value="0.5" />
            </Style>
            <Style x:Key="FormEntry" TargetType="Entry">
                <Setter Property="BackgroundColor"  Value="Transparent" />
                <Setter Property="TextColor"        Value="#F1F1F5" />
                <Setter Property="PlaceholderColor" Value="#3A3A50" />
                <Setter Property="HeightRequest"    Value="44" />
            </Style>
            <Style x:Key="AccentBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#6366F1" />
                <Setter Property="TextColor"       Value="White" />
                <Setter Property="FontAttributes"  Value="Bold" />
                <Setter Property="FontSize"        Value="14" />
                <Setter Property="CornerRadius"    Value="8" />
                <Setter Property="HeightRequest"   Value="42" />
            </Style>
            <Style x:Key="GhostBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#1A1A24" />
                <Setter Property="TextColor"       Value="#9999B0" />
                <Setter Property="FontAttributes"  Value="Bold" />
                <Setter Property="FontSize"        Value="14" />
                <Setter Property="CornerRadius"    Value="8" />
                <Setter Property="HeightRequest"   Value="42" />
                <Setter Property="BorderColor"     Value="#2A2A38" />
                <Setter Property="BorderWidth"     Value="1" />
            </Style>
            <Style x:Key="RowEdit" TargetType="Button">
                <Setter Property="HeightRequest"   Value="32" />
                <Setter Property="WidthRequest"    Value="80" />
                <Setter Property="CornerRadius"    Value="8" />
                <Setter Property="FontSize"        Value="13" />
                <Setter Property="FontAttributes"  Value="Bold" />
                <Setter Property="Padding"         Value="10,0" />
                <Setter Property="BackgroundColor" Value="#1E1E2E" />
                <Setter Property="TextColor"       Value="#818CF8" />
                <Setter Property="BorderColor"     Value="#2A2A38" />
                <Setter Property="BorderWidth"     Value="1" />
            </Style>
            <Style x:Key="RowDelete" TargetType="Button">
                <Setter Property="HeightRequest"   Value="32" />
                <Setter Property="WidthRequest"    Value="90" />
                <Setter Property="CornerRadius"    Value="8" />
                <Setter Property="FontSize"        Value="13" />
                <Setter Property="FontAttributes"  Value="Bold" />
                <Setter Property="Padding"         Value="10,0" />
                <Setter Property="BackgroundColor" Value="#1E1014" />
                <Setter Property="TextColor"       Value="#EF4444" />
                <Setter Property="BorderColor"     Value="#3A1A1A" />
                <Setter Property="BorderWidth"     Value="1" />
            </Style>
            <Style x:Key="PickerBorder" TargetType="Border">
                <Setter Property="BackgroundColor"  Value="#1A1A24" />
                <Setter Property="StrokeShape"      Value="RoundRectangle 8" />
                <Setter Property="Stroke"           Value="#2A2A38" />
                <Setter Property="StrokeThickness"  Value="1" />
                <Setter Property="HeightRequest"    Value="44" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <!-- ══ MAIN ══ -->
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- ROW 0: HEADER -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto"
                  Padding="16,18,16,12" ColumnSpacing="12">
                <Border Grid.Column="0" BackgroundColor="#111118"
                        StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#2A2A38"
                        Padding="0" HeightRequest="44">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="⌕" FontSize="18" TextColor="#3A3A50"
                               VerticalOptions="Center" Padding="12,0" InputTransparent="True" />
                        <Entry Grid.Column="1" Text="{Binding SearchTerm}"
                               Placeholder="Tìm tên, mã SKU, nhà sản xuất..."
                               PlaceholderColor="#3A3A50" BackgroundColor="Transparent"
                               TextColor="#F1F1F5" HeightRequest="44" VerticalOptions="Center"
                               ReturnType="Search" ClearButtonVisibility="WhileEditing" />
                    </Grid>
                </Border>
                <Button Grid.Column="1" Text="＋ Thêm"
                        Style="{StaticResource AccentBtn}"
                        Command="{Binding OpenCreateFormCommand}"
                        Padding="28,0" />
            </Grid>

            <!-- ROW 1: FILTER BAR -->
            <ScrollView Grid.Row="1" Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never" Padding="16,0,16,14">
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="LỌC" FontSize="13" FontAttributes="Bold"
                           CharacterSpacing="1.5" TextColor="#3A3A50"
                           VerticalOptions="Center" Margin="0,0,4,0" />

                    <!-- Loại phụ tùng -->
                    <Border Style="{StaticResource PickerBorder}" WidthRequest="148">
                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">
                            <Label Text="{Binding SelectedCategoryText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCategoryFilterTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Tồn kho -->
                    <Border Style="{StaticResource PickerBorder}" WidthRequest="130">
                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">
                            <Label Text="{Binding SelectedInStockText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnInStockFilterTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Lỗi -->
                    <Border Style="{StaticResource PickerBorder}" WidthRequest="130">
                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">
                            <Label Text="{Binding SelectedDefectiveText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDefectiveFilterTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Hạn -->
                    <Border Style="{StaticResource PickerBorder}" WidthRequest="130">
                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">
                            <Label Text="{Binding SelectedExpiredText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnExpiredFilterTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Trạng thái bán -->
                    <Border Style="{StaticResource PickerBorder}" WidthRequest="130">
                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">
                            <Label Text="{Binding SelectedDiscontinuedText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />
                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDiscontinuedFilterTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <Button Text="✕" IsVisible="{Binding HasActiveFilters}"
                            Command="{Binding ClearFiltersCommand}"
                            BackgroundColor="#1E1014" TextColor="#EF4444"
                            BorderColor="#3A1A1A" BorderWidth="1"
                            FontSize="13" CornerRadius="8"
                            HeightRequest="36" WidthRequest="36" Padding="0" />

                    <BoxView WidthRequest="1" HeightRequest="20"
                             BackgroundColor="#2A2A38" VerticalOptions="Center" Margin="4,0" />

                    <Label VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding TotalCount}" FontAttributes="Bold"
                                      TextColor="#F1F1F5" FontSize="14" />
                                <Span Text=" kết quả" TextColor="#6B6B80" FontSize="13" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- ROW 2: LIST -->
            <Grid Grid.Row="2">
                <CollectionView ItemsSource="{Binding Parts}"
                                IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                Margin="16,0" VerticalOptions="Fill">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="pkt:PartDto">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="14,12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="4"
                                                         VerticalOptions="Center" InputTransparent="True">
                                        <!-- Tên + badges -->
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding PartName}"
                                                   FontSize="17" FontAttributes="Bold"
                                                   TextColor="#F1F1F5" VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" MaxLines="1" />
                                            <Border Style="{StaticResource BadgeStyle}"
                                                    BackgroundColor="{Binding PartCategory, Converter={StaticResource CategoryColor}}">
                                                <Label Text="{Binding PartCategory, Converter={StaticResource EnumText}}"
                                                       FontSize="12" FontAttributes="Bold" TextColor="Black" />
                                            </Border>
                                            <!-- Badge lỗi -->
                                            <Border Style="{StaticResource BadgeStyle}"
                                                    BackgroundColor="#3A1A1A"
                                                    IsVisible="{Binding IsDefective}">
                                                <Label Text="Bị lỗi"
                                                       FontSize="10" FontAttributes="Bold"
                                                       TextColor="#EF4444" />
                                            </Border>
                                            <!-- Badge ngừng bán -->
                                            <Border Style="{StaticResource BadgeStyle}"
                                                    BackgroundColor="#3A1A1A"
                                                    IsVisible="{Binding IsDiscontinued}">
                                                <Label Text="Ngừng bán"
                                                        FontSize="10" FontAttributes="Bold"
                                                        TextColor="#EF4444" />
                                            </Border>
                                            <!-- Badge tồn kho -->
                                            <Border Style="{StaticResource BadgeStyle}" BackgroundColor="#102018">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding InventoryQuantity}" Value="0">
                                                        <Setter Property="BackgroundColor" Value="#1E1014" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="Còn hàng"
                                                       FontSize="10"
                                                       FontAttributes="Bold"
                                                       TextColor="#22C55E">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding InventoryQuantity}" Value="0">
                                                            <Setter Property="Text" Value="Hết hàng" />
                                                            <Setter Property="TextColor" Value="#EF4444" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>
                                        </HorizontalStackLayout>

                                        <!-- Mã SKU + Nhà SX -->
                                        <HorizontalStackLayout Spacing="10">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="SKU:" Style="{StaticResource MutedLabel}" />
                                                <Label Text="{Binding PartCode}"
                                                       FontSize="14" TextColor="#6366F1"
                                                       FontAttributes="Bold" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <Label Text="·" TextColor="#3A3A50" FontSize="12" VerticalOptions="Center" />
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="🏭" FontSize="13" VerticalOptions="Center" />
                                                <Label Text="{Binding Manufacturer}"
                                                       Style="{StaticResource MutedLabel}" />
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- Giá nhập / Giá bán -->
                                        <HorizontalStackLayout Spacing="10">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="Nhập:" Style="{StaticResource MutedLabel}" />
                                                <Label Text="{Binding PurchasePrice, Converter={StaticResource ToCurrency}}"
                                                       FontSize="13" TextColor="#6B6B80" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <Label Text="→" TextColor="#3A3A50" FontSize="11" VerticalOptions="Center" />
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="Bán:" Style="{StaticResource MutedLabel}" />
                                                <Label Text="{Binding SellingPrice, Converter={StaticResource ToCurrency}}"
                                                       FontSize="13" TextColor="#22C55E"
                                                       FontAttributes="Bold" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- Số lượng + Ngày -->
                                        <HorizontalStackLayout Spacing="10">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="📦" FontSize="14" VerticalOptions="Center" />
                                                <Label Style="{StaticResource MutedLabel}">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding InventoryQuantity}"
                                                                  FontAttributes="Bold" TextColor="#C4C4D4" />
                                                            <Span Text=" trong kho" TextColor="#6B6B80" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- Hạn dùng -->
                                        <HorizontalStackLayout Spacing="4" IsVisible="{Binding ExpiryDate, Converter={StaticResource InverseBool}}">
                                            <HorizontalStackLayout>
                                                <Label Text="📅" FontSize="13" VerticalOptions="Center" />
                                                <Label Text="{Binding DateAdded, Converter={StaticResource ToDateStr}}"
                                                       Style="{StaticResource MutedLabel}" />
                                            </HorizontalStackLayout>
                                            <Label Text="·" TextColor="#3A3A50" FontSize="12" VerticalOptions="Center" />
                                            <Label Text="⏰" FontSize="13" VerticalOptions="Center" />
                                            <Label Text="{Binding ExpiryDate, Converter={StaticResource ToDateStr}, TargetNullValue='Không hạn'}"
                                                   Style="{StaticResource MutedLabel}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Actions -->
                                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Button Text="✏ Sửa" Style="{StaticResource RowEdit}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenEditFormCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Text="🗑 Xóa" Style="{StaticResource RowDelete}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.RequestDeleteCommand}"
                                                CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   InputTransparent="True" Color="#6366F1"
                                   HeightRequest="40" WidthRequest="40"
                                   VerticalOptions="Center" HorizontalOptions="Center" />

                <VerticalStackLayout IsVisible="{Binding IsEmpty}" InputTransparent="True"
                                     VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                    <Label Text="—" FontSize="40" FontAttributes="Bold"
                           TextColor="#2A2A38" HorizontalOptions="Center" />
                    <Label Text="Không có phụ tùng" FontSize="16" FontAttributes="Bold"
                           TextColor="#3A3A50" HorizontalOptions="Center" />
                    <Label Text="Nhấn ＋ Thêm để bắt đầu"
                           FontSize="13" TextColor="#2A2A38" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <Border IsVisible="{Binding HasError}" InputTransparent="True"
                        BackgroundColor="#1E1014" StrokeShape="RoundRectangle 8"
                        StrokeThickness="1" Stroke="#3A1A1A"
                        Margin="16,8" Padding="14,10" VerticalOptions="Start">
                    <Label Text="{Binding ErrorMessage}" TextColor="#EF4444" FontSize="13" />
                </Border>
            </Grid>

            <!-- ROW 3: PAGINATION -->
            <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto"
                  Padding="16,10,16,16" ColumnSpacing="12">
                <Button Grid.Column="0" Text="← Trước"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding HasPreviousPage}"
                        Style="{StaticResource GhostBtn}" Padding="16,0" />
                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center"
                                       VerticalOptions="Center" Spacing="4" InputTransparent="True">
                    <Label Text="{Binding CurrentPage}" FontSize="14" FontAttributes="Bold"
                           TextColor="#6366F1" VerticalOptions="Center" />
                    <Label Text="/" FontSize="13" TextColor="#3A3A50" VerticalOptions="Center" />
                    <Label Text="{Binding TotalPages}" FontSize="13"
                           TextColor="#6B6B80" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <Button Grid.Column="2" Text="Tiếp →"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding HasNextPage}"
                        Style="{StaticResource GhostBtn}" Padding="16,0" />
            </Grid>

        </Grid>

        <!-- ══ OVERLAY: FORM THÊM/SỬA ══ -->
        <Grid IsVisible="{Binding IsFormVisible}" ZIndex="20">
            <BoxView BackgroundColor="#70000010" InputTransparent="False">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseFormCommand}" />
                </BoxView.GestureRecognizers>
            </BoxView>
            <Border BackgroundColor="#111118" StrokeShape="RoundRectangle 14"
                    Stroke="#2A2A38" StrokeThickness="1"
                    Margin="20,0" MaximumWidthRequest="600"
                    VerticalOptions="Center" HorizontalOptions="Center" Padding="28,24">
                <ScrollView Padding="0,0,20,0">
                    <VerticalStackLayout Spacing="0">

                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                            <Label Grid.Column="0" Text="{Binding FormTitle}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#F1F1F5" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="✕" Command="{Binding CloseFormCommand}"
                                    BackgroundColor="Transparent" TextColor="#3A3A50"
                                    FontSize="18" Padding="0" WidthRequest="32" HeightRequest="32" />
                        </Grid>

                        <!-- Mã SKU + Tên -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="MÃ SKU *" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormPartCode}"
                                           Placeholder="VD: BP001A" IsReadOnly="{Binding IsEditing}"
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="TÊN PHỤ TÙNG *" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormPartName}"
                                           Placeholder="Nhập tên phụ tùng..."
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Nhà SX + NCC -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="NHÀ SẢN XUẤT" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormManufacturer}"
                                           Placeholder="Bosch, Denso, NGK..."
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="NHÀ CUNG CẤP *" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormSupplierId}"
                                           Placeholder="Nhập mã NCC..."
                                           Keyboard="Numeric"
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Loại phụ tùng -->
                        <Label Text="LOẠI PHỤ TÙNG" Style="{StaticResource FieldLabel}" />
                        <Border Style="{StaticResource PickerBorder}">
                            <Grid ColumnDefinitions="*,Auto" Padding="12,0">
                                <Label Text="{Binding SelectedFormCategoryText}"
                                       TextColor="#F1F1F5"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="1" />
                                <Label Grid.Column="1" Text="▾"
                                       TextColor="#6B6B80"
                                       VerticalOptions="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFormCategoryTapped" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Border>

                        <!-- Giá nhập + Giá bán -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="GIÁ NHẬP (VNĐ) *" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormPurchasePrice}"
                                           Placeholder="0" Keyboard="Numeric"
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="GIÁ BÁN (VNĐ) *" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormSellingPrice}"
                                           Placeholder="0" Keyboard="Numeric"
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Số lượng + Ngày nhập -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="SỐ LƯỢNG *" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}" Padding="0">
                                    <Entry Text="{Binding FormInventoryQuantity}"
                                           Placeholder="0" Keyboard="Numeric"
                                           Style="{StaticResource FormEntry}" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="NGÀY NHẬP KHO" Style="{StaticResource FieldLabel}" />
                                <Border Style="{StaticResource InputBorder}">
                                    <DatePicker Date="{Binding FormDateAdded}"
                                                Format="dd/MM/yyyy"
                                                TextColor="#C4C4D4"
                                                BackgroundColor="Transparent"
                                                VerticalOptions="Center" 
                                                WidthRequest="254" />
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Ngày hết hạn -->
                        <Label Text="NGÀY HẾT HẠN" Style="{StaticResource FieldLabel}" />
                        <Border Style="{StaticResource InputBorder}">
                            <DatePicker Date="{Binding FormExpiryDate, TargetNullValue={x:Static sys:DateTime.Today}}"
                                        Format="dd/MM/yyyy"
                                        TextColor="#C4C4D4"
                                        BackgroundColor="Transparent"
                                        VerticalOptions="Center" 
                                        WidthRequest="521" />
                        </Border>

                        <!-- Bị lỗi + Ngừng bán toggles -->
                        <Grid ColumnDefinitions="*,Auto,*,Auto" ColumnSpacing="0" Margin="0,12,0,0">
                            <Label Grid.Column="0" Text="BỊ LỖI"
                                   Style="{StaticResource FieldLabel}"
                                   VerticalOptions="Center" Margin="0" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding FormIsDefective}"
                                    OnColor="#EF4444" ThumbColor="White"
                                    HeightRequest="30" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="NGỪNG BÁN"
                                   Style="{StaticResource FieldLabel}"
                                   VerticalOptions="Center" Margin="12,0,0,0" />
                            <Switch Grid.Column="3"
                                    IsToggled="{Binding FormIsDiscontinued}"
                                    OnColor="#EF4444" ThumbColor="White"
                                    HeightRequest="30" VerticalOptions="Center" />
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#2A2A38" Margin="0,20,0,0" />

                        <Border IsVisible="{Binding HasFormError}"
                                BackgroundColor="#1E1014" StrokeShape="RoundRectangle 8"
                                StrokeThickness="1" Stroke="#3A1A1A"
                                Padding="12,8" Margin="0,12,0,0">
                            <Label Text="{Binding FormErrorMessage}" TextColor="#EF4444" FontSize="13" />
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">
                            <Button Grid.Column="0" Text="Hủy"
                                    Style="{StaticResource GhostBtn}"
                                    Command="{Binding CloseFormCommand}" />
                            <Button Grid.Column="1" Text="{Binding FormSaveText}"
                                    Style="{StaticResource AccentBtn}"
                                    Command="{Binding SaveFormCommand}" />
                        </Grid>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- ══ OVERLAY: XÁC NHẬN XÓA ══ -->
        <Grid IsVisible="{Binding IsDeleteConfirmVisible}" ZIndex="30">
            <BoxView BackgroundColor="#70000010" />
            <Border BackgroundColor="#111118" StrokeShape="RoundRectangle 14"
                    Stroke="#3A1A1A" StrokeThickness="1"
                    Margin="48,0" MaximumWidthRequest="380"
                    VerticalOptions="Center" HorizontalOptions="Center" Padding="28,24">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Xác nhận xóa" FontSize="18" FontAttributes="Bold"
                           TextColor="#F1F1F5" HorizontalOptions="Center" />
                    <Label HorizontalOptions="Center" HorizontalTextAlignment="Center" FontSize="14">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Xóa vĩnh viễn " TextColor="#6B6B80" />
                                <Span Text="{Binding DeleteConfirmName}"
                                      FontAttributes="Bold" TextColor="#F1F1F5" />
                                <Span Text="?&#10;" TextColor="#6B6B80" />
                                <Span Text="Hành động này không thể hoàn tác."
                                      TextColor="#3A3A50" FontSize="12" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                    <BoxView HeightRequest="1" BackgroundColor="#2A2A38" Margin="0,4,0,4" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Hủy"
                                Style="{StaticResource GhostBtn}"
                                Command="{Binding CancelDeleteCommand}" />
                        <Button Grid.Column="1" Text="Xóa"
                                BackgroundColor="#EF4444" TextColor="White"
                                FontAttributes="Bold" FontSize="14"
                                CornerRadius="8" HeightRequest="42"
                                Command="{Binding ConfirmDeleteCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══ OVERLAY: POPUP LỖI ══ -->
        <Grid IsVisible="{Binding IsPopupVisible}" ZIndex="40">
            <BoxView BackgroundColor="#70000010" />
            <Border BackgroundColor="#111118" StrokeShape="RoundRectangle 14"
                    Stroke="#2A2A38" StrokeThickness="1"
                    Margin="48,0" MaximumWidthRequest="360"
                    VerticalOptions="Center" HorizontalOptions="Center" Padding="28,24">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding PopupTitle}" FontSize="17" FontAttributes="Bold"
                           TextColor="#F1F1F5" HorizontalOptions="Center" />
                    <Label Text="{Binding PopupMessage}" FontSize="13" TextColor="#6B6B80"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    <Button Text="{Binding PopupButtonText}"
                            IsVisible="{Binding IsPopupRetry}"
                            Command="{Binding RetryLoadCommand}"
                            Style="{StaticResource AccentBtn}" />
                    <Button Text="Đóng" IsVisible="{Binding IsPopupNotRetry}"
                            Command="{Binding ClosePopupCommand}"
                            Style="{StaticResource GhostBtn}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
