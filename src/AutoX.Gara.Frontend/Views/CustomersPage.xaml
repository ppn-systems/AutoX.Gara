<?xml version="1.0" encoding="utf-8" ?>

<!--

    CustomersPage.xaml — Minimal / Modern Dark

    ─────────────────────────────────────────────

    Palette:

      Background    #0A0A0F  (near-black)

      Surface       #111118  (card)

      Surface 2     #1A1A24  (input / picker)

      Border        #2A2A38

      Accent        #6366F1  (indigo)

      Accent hover  #818CF8

      Text primary  #F1F1F5

      Text muted    #6B6B80

      Danger        #EF4444

      Success       #22C55E

-->

<ContentPage

    x:Name="PageRoot"

    x:Class="AutoX.Gara.Frontend.Views.CustomersPage"

    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"

    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"

    xmlns:ctrl="clr-namespace:AutoX.Gara.Frontend.Controllers"

    xmlns:sys="clr-namespace:System;assembly=System.Runtime"

    xmlns:pkt="clr-namespace:AutoX.Gara.Contracts.Customers;assembly=AutoX.Gara.Contracts"

    xmlns:conv="clr-namespace:AutoX.Gara.Frontend.Converters"

    x:DataType="ctrl:CustomersViewModel"

    Title="Quản lý khách hàng"

    BackgroundColor="#0A0A0F">

    <ContentPage.Resources>

        <ResourceDictionary>

            <conv:CustomerTypeToColorConverter   x:Key="TypeToColor"   />

            <conv:CustomerTypeToLabelConverter   x:Key="TypeToLabel"   />

            <conv:MembershipToColorConverter     x:Key="MemberToColor" />

            <conv:MembershipToLabelConverter     x:Key="MemberToLabel" />

            <conv:InitialsConverter              x:Key="ToInitials"    />

            <conv:InitialsBackgroundConverter    x:Key="InitialsBg"    />

            <conv:DateTimeToShortStringConverter x:Key="ToShortDate"   />

            <conv:StringNotEmptyConverter        x:Key="NotEmpty"      />

            <conv:InverseBoolConverter           x:Key="InverseBool"   />

            <conv:EnumTextConverter              x:Key="EnumText"      />

            <!-- Surface card — viền mỏng, không shadow nặng -->

            <Style x:Key="CardStyle" TargetType="Border">

                <Setter Property="BackgroundColor"  Value="#111118" />

                <Setter Property="StrokeShape"      Value="RoundRectangle 10" />

                <Setter Property="Stroke"           Value="#2A2A38" />

                <Setter Property="StrokeThickness"  Value="1" />

            </Style>

            <!-- Input field -->

            <Style x:Key="InputBorder" TargetType="Border">

                <Setter Property="BackgroundColor"  Value="#1A1A24" />

                <Setter Property="StrokeShape"      Value="RoundRectangle 8" />

                <Setter Property="Stroke"           Value="#2A2A38" />

                <Setter Property="StrokeThickness"  Value="1" />

                <Setter Property="HeightRequest"    Value="44" />

            </Style>

            <!-- Badge pill -->

            <Style x:Key="BadgeStyle" TargetType="Border">

                <Setter Property="StrokeShape"      Value="RoundRectangle 4" />

                <Setter Property="StrokeThickness"  Value="0" />

                <Setter Property="Padding"          Value="6,2" />

                <Setter Property="VerticalOptions"  Value="Center" />

                <Setter Property="InputTransparent" Value="True" />

            </Style>

            <!-- Muted text -->

            <Style x:Key="MutedLabel" TargetType="Label">

                <Setter Property="FontSize"         Value="12" />

                <Setter Property="TextColor"        Value="#6B6B80" />

                <Setter Property="VerticalOptions"  Value="Center" />

            </Style>

            <!-- Form field label -->

            <Style x:Key="FieldLabel" TargetType="Label">

                <Setter Property="FontSize"         Value="12" />

                <Setter Property="FontAttributes"   Value="Bold" />

                <Setter Property="TextColor"        Value="#6B6B80" />

                <Setter Property="Margin"           Value="0,12,0,5" />

                <Setter Property="CharacterSpacing" Value="0.5" />

            </Style>

            <!-- Form entry -->

            <Style x:Key="FormEntry" TargetType="Entry">

                <Setter Property="BackgroundColor"  Value="Transparent" />

                <Setter Property="TextColor"        Value="#F1F1F5" />

                <Setter Property="PlaceholderColor" Value="#3A3A50" />

                <Setter Property="HeightRequest"    Value="44" />

            </Style>

            <!-- Accent button -->

            <Style x:Key="AccentBtn" TargetType="Button">

                <Setter Property="BackgroundColor"  Value="#6366F1" />

                <Setter Property="TextColor"        Value="White" />

                <Setter Property="FontAttributes"   Value="Bold" />

                <Setter Property="FontSize"         Value="14" />

                <Setter Property="CornerRadius"     Value="8" />

                <Setter Property="HeightRequest"    Value="42" />

            </Style>

            <!-- Ghost button -->

            <Style x:Key="GhostBtn" TargetType="Button">

                <Setter Property="BackgroundColor"  Value="#1A1A24" />

                <Setter Property="TextColor"        Value="#9999B0" />

                <Setter Property="FontAttributes"   Value="Bold" />

                <Setter Property="FontSize"         Value="14" />

                <Setter Property="CornerRadius"     Value="8" />

                <Setter Property="HeightRequest"    Value="42" />

                <Setter Property="BorderColor"      Value="#2A2A38" />

                <Setter Property="BorderWidth"      Value="1" />

            </Style>

            <!-- Row actions — pill buttons có text label -->

            <Style x:Key="RowVehicle" TargetType="Button">

                <Setter Property="HeightRequest"   Value="32" />

                <Setter Property="WidthRequest"    Value="80" />

                <Setter Property="CornerRadius"    Value="8" />

                <Setter Property="FontSize"        Value="13" />

                <Setter Property="FontAttributes"  Value="Bold" />

                <Setter Property="Padding"         Value="10,0" />

                <Setter Property="BackgroundColor" Value="#0D1F14" />

                <Setter Property="TextColor"       Value="#22C55E" />

                <Setter Property="BorderColor"     Value="#1A3A24" />

                <Setter Property="BorderWidth"     Value="1" />

            </Style>

            <Style x:Key="RowEdit" TargetType="Button">

                <Setter Property="HeightRequest"   Value="32" />

                <Setter Property="WidthRequest"    Value="80" />

                <Setter Property="CornerRadius"    Value="8" />

                <Setter Property="FontSize"        Value="13" />

                <Setter Property="FontAttributes"  Value="Bold" />

                <Setter Property="Padding"         Value="10,0" />

                <Setter Property="BackgroundColor" Value="#1E1E2E" />

                <Setter Property="TextColor"       Value="#818CF8" />

                <Setter Property="BorderColor"     Value="#2A2A38" />

                <Setter Property="BorderWidth"     Value="1" />

            </Style>

            <Style x:Key="RowDelete" TargetType="Button">

                <Setter Property="HeightRequest"   Value="32" />

                <Setter Property="WidthRequest"    Value="80" />

                <Setter Property="CornerRadius"    Value="8" />

                <Setter Property="FontSize"        Value="13" />

                <Setter Property="FontAttributes"  Value="Bold" />

                <Setter Property="Padding"         Value="10,0" />

                <Setter Property="BackgroundColor" Value="#1E1014" />

                <Setter Property="TextColor"       Value="#EF4444" />

                <Setter Property="BorderColor"     Value="#3A1A1A" />

                <Setter Property="BorderWidth"     Value="1" />

            </Style>

            <!-- Picker container -->

            <Style x:Key="PickerBorder" TargetType="Border">

                <Setter Property="BackgroundColor"  Value="#1A1A24" />

                <Setter Property="StrokeShape"      Value="RoundRectangle 8" />

                <Setter Property="Stroke"           Value="#2A2A38" />

                <Setter Property="StrokeThickness"  Value="1" />

                <Setter Property="HeightRequest"    Value="44" />

            </Style>

        </ResourceDictionary>

    </ContentPage.Resources>

    <Grid>

        <!-- ══════════════════════════════════════════════════

             MAIN — 4 rows

             ══════════════════════════════════════════════════ -->

        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="0">

            <!-- ─────────── ROW 0: HEADER ─────────── -->

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto"

                  Padding="16,18,16,12" ColumnSpacing="12">

                <!-- Search -->

                <Border Grid.Column="0"

                        BackgroundColor="#111118"

                        StrokeShape="RoundRectangle 8"

                        StrokeThickness="1" Stroke="#2A2A38"

                        Padding="0,0" HeightRequest="44">

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">

                        <Label Grid.Column="0" Text="⌕"

                               FontSize="18" TextColor="#3A3A50"

                               VerticalOptions="Center"

                               InputTransparent="True" 

                               Padding="12,0"/>

                        <Entry Grid.Column="1"

                               Text="{Binding SearchTerm}"

                               Placeholder="Tìm tên, email, số điện thoại..."

                               PlaceholderColor="#3A3A50"

                               BackgroundColor="Transparent"

                               TextColor="#F1F1F5"

                               HeightRequest="44"

                               VerticalOptions="Center"

                               ReturnType="Search"

                               ClearButtonVisibility="WhileEditing" />

                    </Grid>

                </Border>

                <!-- Nút Thêm -->

                <Button Grid.Column="1"

                        Text="＋ Thêm"

                        Style="{StaticResource AccentBtn}"

                        Command="{Binding OpenCreateFormCommand}"

                        Padding="28,0" />

            </Grid>

            <!-- ─────────── ROW 1: FILTER BAR ─────────── -->

            <ScrollView Grid.Row="1"

                        Orientation="Horizontal"

                        HorizontalScrollBarVisibility="Never"

                        Padding="16,0,16,14">

                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">

                    <!-- Divider label -->

                    <Label Text="LỌC"

                           FontSize="13" FontAttributes="Bold"

                           CharacterSpacing="1.5"

                           TextColor="#3A3A50"

                           VerticalOptions="Center"

                           Margin="0,0,4,0" />

                    <!-- Picker Loại KH -->

                    <Border Style="{StaticResource PickerBorder}" WidthRequest="148">

                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">

                            <Label Text="{Binding SelectedFilterTypeText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />

                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />

                            <Grid.GestureRecognizers>

                                <TapGestureRecognizer Tapped="OnFilterTypeTapped" />

                            </Grid.GestureRecognizers>

                        </Grid>

                    </Border>

                    <!-- Picker Hạng -->

                    <Border Style="{StaticResource PickerBorder}" WidthRequest="148">

                        <Grid ColumnDefinitions="*,Auto" Padding="12,0">

                            <Label Text="{Binding SelectedMembershipText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />

                            <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />

                            <Grid.GestureRecognizers>

                                <TapGestureRecognizer Tapped="OnMembershipTapped" />

                            </Grid.GestureRecognizers>

                        </Grid>

                    </Border>

                    <!-- Bỏ lọc -->

                    <Button Text="✕"

                            IsVisible="{Binding HasActiveFilters}"

                            Command="{Binding ClearFiltersCommand}"

                            BackgroundColor="#1E1014"

                            TextColor="#EF4444"

                            BorderColor="#3A1A1A" BorderWidth="1"

                            FontSize="13" CornerRadius="8"

                            HeightRequest="36" WidthRequest="36"

                            Padding="0" />

                    <!-- Separator -->

                    <BoxView WidthRequest="1" HeightRequest="20"

                             BackgroundColor="#2A2A38"

                             VerticalOptions="Center" Margin="4,0" />

                    <!-- Count -->

                    <Label VerticalOptions="Center">

                        <Label.FormattedText>

                            <FormattedString>

                                <Span Text="{Binding TotalCount}"

                                      FontAttributes="Bold"

                                      TextColor="#F1F1F5"

                                      FontSize="14" />

                                <Span Text=" kết quả"

                                      TextColor="#6B6B80"

                                      FontSize="13" />

                            </FormattedString>

                        </Label.FormattedText>

                    </Label>

                </HorizontalStackLayout>

            </ScrollView>

            <!-- ─────────── ROW 2: LIST ─────────── -->

            <Grid Grid.Row="2">

                <!-- CollectionView -->

                <CollectionView

                    ItemsSource="{Binding Customers}"
                    ItemSizingStrategy="MeasureFirstItem"

                    IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}"

                    Margin="16,0" VerticalOptions="Fill">

                    <CollectionView.ItemTemplate>

                        <DataTemplate x:DataType="pkt:CustomerDto">

                            <!-- Row card — viền trái accent subtle -->

                            <Border Style="{StaticResource CardStyle}"

                                    Margin="0,0,0,8" Padding="14,12">

                                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">

                                    <!-- Avatar circle -->

                                    <Border Grid.Column="0"

                                            BackgroundColor="{Binding Name, Converter={StaticResource InitialsBg}}"

                                            StrokeShape="RoundRectangle 20"

                                            StrokeThickness="0"

                                            WidthRequest="40" HeightRequest="40"

                                            VerticalOptions="Center"

                                            InputTransparent="True">

                                        <Label Text="{Binding Name, Converter={StaticResource ToInitials}}"

                                               TextColor="White"

                                               FontSize="16" FontAttributes="Bold"

                                               HorizontalOptions="Center"

                                               VerticalOptions="Center" />

                                    </Border>

                                    <!-- Info -->

                                    <VerticalStackLayout Grid.Column="1"

                                                         Spacing="3"

                                                         VerticalOptions="Center"

                                                         InputTransparent="True">

                                        <!-- Tên + badges -->

                                        <HorizontalStackLayout Spacing="6">

                                            <Label Text="{Binding Name}"

                                                   FontSize="16" FontAttributes="Bold"

                                                   TextColor="#F1F1F5"

                                                   VerticalOptions="Center"

                                                   LineBreakMode="TailTruncation" MaxLines="1" />

                                            <Border Style="{StaticResource BadgeStyle}"

                                                    BackgroundColor="{Binding Type, Converter={StaticResource TypeToColor}, ConverterParameter=dark}">

                                            <Label Text="{Binding Type, Converter={StaticResource EnumText}}"

                                                   FontSize="12" FontAttributes="Bold"

                                                   TextColor="White" />

                                            </Border>

                                            <Border Style="{StaticResource BadgeStyle}"

                                                    BackgroundColor="{Binding Membership, Converter={StaticResource MemberToColor}}">

                                            <Label Text="{Binding Membership, Converter={StaticResource EnumText}}"

                                                   FontSize="12" FontAttributes="Bold"

                                                   TextColor="White" />

                                            </Border>

                                        </HorizontalStackLayout>

                                        <!-- SĐT -->

                                        <HorizontalStackLayout Spacing="5">

                                            <Label Text="📞" FontSize="13" VerticalOptions="Center" />

                                            <Label Text="{Binding PhoneNumber}"

                                                   Style="{StaticResource MutedLabel}" />

                                        </HorizontalStackLayout>

                                        <!-- Email -->

                                        <HorizontalStackLayout Spacing="5">

                                            <Label Text="✉" FontSize="13" VerticalOptions="Center" />

                                            <Label Text="{Binding Email}"

                                                   Style="{StaticResource MutedLabel}"

                                                   LineBreakMode="TailTruncation" MaxLines="1" />

                                        </HorizontalStackLayout>

                                        <!-- Địa chỉ -->

                                        <HorizontalStackLayout Spacing="5"

                                            IsVisible="{Binding Address, Converter={StaticResource NotEmpty}}">

                                            <Label Text="📍" FontSize="11" VerticalOptions="Center" />

                                            <Label Text="{Binding Address}"

                                                   Style="{StaticResource MutedLabel}"

                                                   LineBreakMode="TailTruncation" MaxLines="1" />

                                        </HorizontalStackLayout>

                                        <!-- Ngày tham gia -->

                                        <HorizontalStackLayout Spacing="5">

                                            <Label Text="·" FontSize="11"

                                                   TextColor="#3A3A50"

                                                   VerticalOptions="Center" />

                                            <Label Text="{Binding CreatedAt, Converter={StaticResource ToShortDate}, StringFormat='Tham gia {0}'}"

                                                   Style="{StaticResource MutedLabel}" />

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                    <!-- Actions -->

                                    <HorizontalStackLayout Grid.Column="2"

                                                           Spacing="6"

                                                           VerticalOptions="Center">

                                        <Button Text="🚗 Xe"

                                                Style="{StaticResource RowVehicle}"

                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenVehiclesCommand}"

                                                CommandParameter="{Binding .}" />

                                        <Button Text="🧾 HĐ"

                                                Style="{StaticResource RowVehicle}"

                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenInvoicesCommand}"

                                                CommandParameter="{Binding .}" />

                                        <Button Text="✏ Sửa"

                                                Style="{StaticResource RowEdit}"

                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenEditFormCommand}"

                                                CommandParameter="{Binding .}" />

                                        <Button Text="🗑 Xóa"

                                                Style="{StaticResource RowDelete}"

                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.RequestDeleteCommand}"

                                                CommandParameter="{Binding .}" />

                                    </HorizontalStackLayout>

                                </Grid>

                            </Border>

                        </DataTemplate>

                    </CollectionView.ItemTemplate>

                </CollectionView>

                <!-- Loading -->

                <ActivityIndicator

                    IsRunning="{Binding IsLoading}"

                    IsVisible="{Binding IsLoading}"

                    InputTransparent="True"

                    Color="#6366F1"

                    HeightRequest="40" WidthRequest="40"

                    VerticalOptions="Center" HorizontalOptions="Center" />

                <!-- Empty state -->

                <VerticalStackLayout

                    IsVisible="{Binding IsEmpty}"

                    InputTransparent="True"

                    VerticalOptions="Center" HorizontalOptions="Center"

                    Spacing="8">

                    <Label Text="—"

                           FontSize="40" FontAttributes="Bold"

                           TextColor="#2A2A38"

                           HorizontalOptions="Center" />

                    <Label Text="Không có khách hàng"

                           FontSize="16" FontAttributes="Bold"

                           TextColor="#3A3A50"

                           HorizontalOptions="Center" />

                    <Label Text="Nhấn ＋ Thêm để bắt đầu"

                           FontSize="13" TextColor="#2A2A38"

                           HorizontalOptions="Center" />

                </VerticalStackLayout>

                <!-- Error -->

                <Border IsVisible="{Binding HasError}"

                        InputTransparent="True"

                        BackgroundColor="#1E1014"

                        StrokeShape="RoundRectangle 8"

                        StrokeThickness="1" Stroke="#3A1A1A"

                        Margin="16,8" Padding="14,10"

                        VerticalOptions="Start">

                    <Label Text="{Binding ErrorMessage}"

                           TextColor="#EF4444" FontSize="13" />

                </Border>

            </Grid>

            <!-- ─────────── ROW 3: PAGINATION ─────────── -->

            <Grid Grid.Row="3"

                  ColumnDefinitions="Auto,*,Auto"

                  Padding="16,10,16,16" ColumnSpacing="12">

                <Button Grid.Column="0"

                        Text="← Trước"

                        Command="{Binding PreviousPageCommand}"

                        IsEnabled="{Binding HasPreviousPage}"

                        Style="{StaticResource GhostBtn}"

                        Padding="16,0" />

                <HorizontalStackLayout Grid.Column="1"

                                       HorizontalOptions="Center"

                                       VerticalOptions="Center"

                                       Spacing="4"

                                       InputTransparent="True">

                    <Label Text="{Binding CurrentPage}"

                           FontSize="14" FontAttributes="Bold"

                           TextColor="#6366F1"

                           VerticalOptions="Center" />

                    <Label Text="/" FontSize="13"

                           TextColor="#3A3A50"

                           VerticalOptions="Center" />

                    <Label Text="{Binding TotalPages}"

                           FontSize="13" TextColor="#6B6B80"

                           VerticalOptions="Center" />

                </HorizontalStackLayout>

                <Button Grid.Column="2"

                        Text="Tiếp →"

                        Command="{Binding NextPageCommand}"

                        IsEnabled="{Binding HasNextPage}"

                        Style="{StaticResource GhostBtn}"

                        Padding="16,0" />

            </Grid>

        </Grid>

        <!-- /main -->

        <!-- ══════════════════════════════════════════════════

             OVERLAY: FORM ADD / EDIT

             ══════════════════════════════════════════════════ -->

        <Grid IsVisible="{Binding IsFormVisible}" ZIndex="20">

            <BoxView BackgroundColor="#70000010" InputTransparent="False">

                <BoxView.GestureRecognizers>

                    <TapGestureRecognizer Command="{Binding CloseFormCommand}" />

                </BoxView.GestureRecognizers>

            </BoxView>

            <Border BackgroundColor="#111118"

                    StrokeShape="RoundRectangle 14"

                    Stroke="#2A2A38" StrokeThickness="1"

                    Margin="20,0"

                    MaximumWidthRequest="580"

                    VerticalOptions="Center"

                    HorizontalOptions="Center"

                    Padding="28,24">

                <ScrollView Padding="0,0,20,0">

                    <VerticalStackLayout Spacing="0">

                        <!-- Header -->

                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">

                            <Label Grid.Column="0"

                                   Text="{Binding FormTitle}"

                                   FontSize="20" FontAttributes="Bold"

                                   TextColor="#F1F1F5"

                                   VerticalOptions="Center" />

                            <Button Grid.Column="1" Text="✕"

                                    Command="{Binding CloseFormCommand}"

                                    BackgroundColor="Transparent"

                                    TextColor="#3A3A50"

                                    FontSize="18" Padding="0"

                                    WidthRequest="32" HeightRequest="32" />

                        </Grid>

                        <!-- Họ và tên -->

                        <Label Text="HỌ VÀ TÊN *" Style="{StaticResource FieldLabel}" />

                        <Border Style="{StaticResource InputBorder}" Padding="0,0,0,0">

                            <Entry Text="{Binding FormName}"

                                   Placeholder="Nhập họ và tên..."

                                   Style="{StaticResource FormEntry}" />

                        </Border>

                        <!-- SĐT + Email -->

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                            <VerticalStackLayout Grid.Column="0">

                                <Label Text="SỐ ĐIỆN THOẠI *" Style="{StaticResource FieldLabel}" />

                                <Border Style="{StaticResource InputBorder}" Padding="0,0">

                                    <Entry Text="{Binding FormPhone}"

                                           Placeholder="0901234567"

                                           Keyboard="Telephone"

                                           Style="{StaticResource FormEntry}" />

                                </Border>

                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">

                                <Label Text="EMAIL *" Style="{StaticResource FieldLabel}" />

                                <Border Style="{StaticResource InputBorder}" Padding="0,0">

                                    <Entry Text="{Binding FormEmail}"

                                           Placeholder="email@example.com"

                                           Keyboard="Email"

                                           Style="{StaticResource FormEntry}" />

                                </Border>

                            </VerticalStackLayout>

                        </Grid>

                        <!-- Loại KH + Hạng -->

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                            <VerticalStackLayout Grid.Column="0">

                                <Label Text="LOẠI KHÁCH HÀNG" Style="{StaticResource FieldLabel}" />

                                <Border Style="{StaticResource PickerBorder}" Padding="0,0">

                                    <Grid ColumnDefinitions="*,Auto" Padding="12,0,12,0">

                                        <Label Text="{Binding SelectedFormTypeText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />

                                        <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />

                                        <Grid.GestureRecognizers>

                                            <TapGestureRecognizer Tapped="OnFormTypeTapped" />

                                        </Grid.GestureRecognizers>

                                    </Grid>

                                </Border>

                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">

                                <Label Text="HẠNG THÀNH VIÊN" Style="{StaticResource FieldLabel}" />

                                <Border Style="{StaticResource PickerBorder}" Padding="0,0">

                                    <Grid ColumnDefinitions="*,Auto" Padding="12,0,12,0">

                                        <Label Text="{Binding SelectedFormMembershipText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />

                                        <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />

                                        <Grid.GestureRecognizers>

                                            <TapGestureRecognizer Tapped="OnFormMembershipTapped" />

                                        </Grid.GestureRecognizers>

                                    </Grid>

                                </Border>

                            </VerticalStackLayout>

                        </Grid>

                        <!-- Địa chỉ -->

                        <Label Text="ĐỊA CHỈ" Style="{StaticResource FieldLabel}" />

                        <Border Style="{StaticResource InputBorder}" Padding="0,0">

                            <Entry Text="{Binding FormAddress}"

                                   Placeholder="Nhập địa chỉ..."

                                   Style="{StaticResource FormEntry}" />

                        </Border>

                        <!-- MST -->

                        <Label Text="MÃ SỐ THUẾ" Style="{StaticResource FieldLabel}" />

                        <Border Style="{StaticResource InputBorder}" Padding="0,0">

                            <Entry Text="{Binding FormTaxCode}"

                                   Placeholder="Nhập MST nếu có..."

                                   Style="{StaticResource FormEntry}" />

                        </Border>

                        <!-- Giới tính + Ngày sinh -->

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                            <VerticalStackLayout Grid.Column="0">

                                <Label Text="GIỚI TÍNH" Style="{StaticResource FieldLabel}" />

                                <Border Style="{StaticResource PickerBorder}">

                                    <Grid ColumnDefinitions="*,Auto" Padding="12,0">

                                        <Label Text="{Binding SelectedFormGenderText}" TextColor="#F1F1F5" VerticalOptions="Center" LineBreakMode="TailTruncation" MaxLines="1" />

                                        <Label Grid.Column="1" Text="▾" TextColor="#6B6B80" VerticalOptions="Center" />

                                        <Grid.GestureRecognizers>

                                            <TapGestureRecognizer Tapped="OnFormGenderTapped" />

                                        </Grid.GestureRecognizers>

                                    </Grid>

                                </Border>

                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1">

                                <Label Text="NGÀY SINH" Style="{StaticResource FieldLabel}" />

                                <Border Style="{StaticResource InputBorder}">

                                    <DatePicker Date="{Binding FormDateOfBirth, TargetNullValue={x:Static sys:DateTime.Today}}"

                                                Format="dd/MM/yyyy"

                                                TextColor="#C4C4D4"

                                                BackgroundColor="Transparent"

                                                VerticalOptions="Center" 

                                                WidthRequest="244" />

                                </Border>

                            </VerticalStackLayout>

                        </Grid>

                        <!-- Ghi chú -->

                        <Label Text="GHI CHÚ" Style="{StaticResource FieldLabel}" />

                        <Border BackgroundColor="#1A1A24"

                                StrokeShape="RoundRectangle 8"

                                Stroke="#2A2A38" StrokeThickness="1"

                                Padding="0,0">

                            <Editor Text="{Binding FormNotes}"

                                    Placeholder="Ghi chú thêm..."

                                    PlaceholderColor="#3A3A50"

                                    TextColor="#F1F1F5"

                                    BackgroundColor="Transparent"

                                    HeightRequest="72"

                                    AutoSize="Disabled" />

                        </Border>

                        <!-- Divider -->

                        <BoxView HeightRequest="1"

                                 BackgroundColor="#2A2A38"

                                 Margin="0,20,0,0" />

                        <!-- Error -->

                        <Border IsVisible="{Binding HasFormError}"

                                BackgroundColor="#1E1014"

                                StrokeShape="RoundRectangle 8"

                                StrokeThickness="1" Stroke="#3A1A1A"

                                Padding="12,8" Margin="0,0,0,12">

                            <Label Text="{Binding FormErrorMessage}"

                                   TextColor="#EF4444" FontSize="13" />

                        </Border>

                        <!-- Buttons -->

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,16,0,0">

                            <Button Grid.Column="0" Text="Hủy"

                                    Style="{StaticResource GhostBtn}"

                                    Command="{Binding CloseFormCommand}" />

                            <Button Grid.Column="1"

                                    Text="{Binding FormSaveText}"

                                    Style="{StaticResource AccentBtn}"

                                    Command="{Binding SaveFormCommand}" />

                        </Grid>

                    </VerticalStackLayout>

                </ScrollView>

            </Border>

        </Grid>

        <!-- /form -->

        <!-- ══════════════════════════════════════════════════

             OVERLAY: XÁC NHẬN XÓA

             ══════════════════════════════════════════════════ -->

        <Grid IsVisible="{Binding IsDeleteConfirmVisible}" ZIndex="30">

            <BoxView BackgroundColor="#70000010" />

            <Border BackgroundColor="#111118"

                    StrokeShape="RoundRectangle 14"

                    Stroke="#3A1A1A" StrokeThickness="1"

                    Margin="48,0" MaximumWidthRequest="380"

                    VerticalOptions="Center" HorizontalOptions="Center"

                    Padding="28,24">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Xác nhận xóa"

                           FontSize="18" FontAttributes="Bold"

                           TextColor="#F1F1F5"

                           HorizontalOptions="Center" />

                    <Label HorizontalOptions="Center"

                           HorizontalTextAlignment="Center"

                           FontSize="14">

                        <Label.FormattedText>

                            <FormattedString>

                                <Span Text="Xóa " TextColor="#6B6B80" />

                                <Span Text="{Binding DeleteConfirmName}"

                                      FontAttributes="Bold" TextColor="#F1F1F5" />

                                <Span Text="?&#10;" TextColor="#6B6B80" />

                                <Span Text="Hành động này không thể hoàn tác."

                                      TextColor="#3A3A50" FontSize="12" />

                            </FormattedString>

                        </Label.FormattedText>

                    </Label>

                    <BoxView HeightRequest="1" BackgroundColor="#2A2A38" Margin="0,4,0,4" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                        <Button Grid.Column="0" Text="Hủy"

                                Style="{StaticResource GhostBtn}"

                                Command="{Binding CancelDeleteCommand}" />

                        <Button Grid.Column="1" Text="Xóa"

                                BackgroundColor="#EF4444" TextColor="White"

                                FontAttributes="Bold" FontSize="14"

                                CornerRadius="8" HeightRequest="42"

                                Command="{Binding ConfirmDeleteCommand}" />

                    </Grid>

                </VerticalStackLayout>

            </Border>

        </Grid>

        <!-- /delete -->

        <!-- ══════════════════════════════════════════════════

             OVERLAY: POPUP LỖI

             ══════════════════════════════════════════════════ -->

        <Grid IsVisible="{Binding IsPopupVisible}" ZIndex="40">

            <BoxView BackgroundColor="#70000010" />

            <Border BackgroundColor="#111118"

                    StrokeShape="RoundRectangle 14"

                    Stroke="#2A2A38" StrokeThickness="1"

                    Margin="48,0" MaximumWidthRequest="360"

                    VerticalOptions="Center" HorizontalOptions="Center"

                    Padding="28,24">

                <VerticalStackLayout Spacing="12">

                    <Label Text="{Binding PopupTitle}"

                           FontSize="17" FontAttributes="Bold"

                           TextColor="#F1F1F5"

                           HorizontalOptions="Center" />

                    <Label Text="{Binding PopupMessage}"

                           FontSize="13"

                           TextColor="#6B6B80"

                           HorizontalOptions="Center"

                           HorizontalTextAlignment="Center" />

                    <Button Text="{Binding PopupButtonText}"

                            IsVisible="{Binding IsPopupRetry}"

                            Command="{Binding RetryLoadCommand}"

                            Style="{StaticResource AccentBtn}" />

                    <Button Text="Đóng"

                            IsVisible="{Binding IsPopupNotRetry}"

                            Command="{Binding ClosePopupCommand}"

                            Style="{StaticResource GhostBtn}" />

                </VerticalStackLayout>

            </Border>

        </Grid>

        <!-- /popup -->

    </Grid>

    <!-- /root -->

</ContentPage>



