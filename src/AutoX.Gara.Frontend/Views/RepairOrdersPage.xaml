<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Name="PageRoot"
    x:Class="AutoX.Gara.Frontend.Views.RepairOrdersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AutoX.Gara.Frontend.ViewModels"
    xmlns:pkt="clr-namespace:AutoX.Gara.Shared.Protocol.Billings;assembly=AutoX.Gara.Shared"
    xmlns:conv="clr-namespace:AutoX.Gara.Frontend.Converters"
    x:DataType="vm:RepairOrdersViewModel"
    Title="{Binding PageTitle}"
    BackgroundColor="#0A0A0F">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter x:Key="InverseBool" />
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#111118" />
                <Setter Property="StrokeShape" Value="RoundRectangle 10" />
                <Setter Property="Stroke" Value="#2A2A38" />
                <Setter Property="StrokeThickness" Value="1" />
            </Style>
            <Style x:Key="AccentBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#6366F1" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="40" />
            </Style>
            <Style x:Key="GhostBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#1A1A24" />
                <Setter Property="TextColor" Value="#F1F1F5" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="40" />
                <Setter Property="BorderColor" Value="#2A2A38" />
                <Setter Property="BorderWidth" Value="1" />
            </Style>
            <Style x:Key="DangerBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#EF4444" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="HeightRequest" Value="40" />
            </Style>
            <Style x:Key="MutedLabel" TargetType="Label">
                <Setter Property="TextColor" Value="#6B6B80" />
                <Setter Property="FontSize" Value="12" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" Padding="14">
        <Grid RowDefinitions="Auto" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <Button Text="←"
                    Style="{StaticResource GhostBtn}"
                    WidthRequest="44"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="{Binding PageTitle}"
                   TextColor="#F1F1F5"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Button Grid.Column="2"
                    Text="+"
                    Style="{StaticResource AccentBtn}"
                    WidthRequest="44"
                    IsVisible="{Binding CanAdd}"
                    Command="{Binding OpenAddFormCommand}" />
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,12,0,0">
            <Label Text="{Binding ErrorMessage}" TextColor="#EF4444" IsVisible="{Binding HasError}" />

            <CollectionView Grid.Row="1" ItemsSource="{Binding RepairOrders}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="pkt:RepairOrderDto">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="12">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10">
                                <Label Text="{Binding RepairOrderId, StringFormat='Lệnh #{0}'}"
                                       TextColor="#F1F1F5" FontAttributes="Bold" />
                                <Label Grid.Column="1" Text="{Binding Status}" Style="{StaticResource MutedLabel}" />

                                <Label Grid.Row="1" Text="{Binding OrderDate, StringFormat='Ngày: {0:dd/MM/yyyy}'}"
                                       Style="{StaticResource MutedLabel}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding TotalRepairCost, StringFormat='Tổng: {0:N0}'}"
                                       Style="{StaticResource MutedLabel}" HorizontalTextAlignment="End" />

                                <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="8" Margin="0,10,0,0">
                                    <Button Text="Task" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenTasksCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Part" Style="{StaticResource GhostBtn}"
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenPartsCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Sửa" Style="{StaticResource AccentBtn}"
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.OpenEditFormCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="Xóa" Style="{StaticResource DangerBtn}"
                                            Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.RequestDeleteCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Form overlay -->
        <Grid IsVisible="{Binding IsFormVisible}" BackgroundColor="#70000010" RowSpan="2">
            <Border Style="{StaticResource CardStyle}"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    Padding="16" WidthRequest="340">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding FormTitle}" TextColor="#F1F1F5" FontAttributes="Bold" />

                    <Label Text="Ngày tạo" Style="{StaticResource MutedLabel}" />
                    <DatePicker Date="{Binding FormOrderDate}" TextColor="#F1F1F5" />

                    <Label Text="Trạng thái" Style="{StaticResource MutedLabel}" />
                    <Picker ItemsSource="{Binding StatusOptions}"
                            SelectedIndex="{Binding PickerStatusIndex}" />

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Có ngày hoàn thành" Style="{StaticResource MutedLabel}" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding HasCompletionDate}" />
                    </HorizontalStackLayout>
                    <DatePicker Date="{Binding FormCompletionDateValue}"
                                IsVisible="{Binding HasCompletionDate}"
                                TextColor="#F1F1F5" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                        <Button Grid.Column="0" Text="Hủy" Style="{StaticResource GhostBtn}" Command="{Binding CancelFormCommand}" />
                        <Button Grid.Column="1" Text="{Binding FormSaveText}" Style="{StaticResource AccentBtn}" Command="{Binding SaveCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Delete confirm overlay -->
        <Grid IsVisible="{Binding IsDeleteConfirmVisible}" BackgroundColor="#70000010" RowSpan="2">
            <Border Style="{StaticResource CardStyle}"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    Padding="16" WidthRequest="320">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding DeleteConfirmTitle}" TextColor="#F1F1F5" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Hủy" Style="{StaticResource GhostBtn}" Command="{Binding CancelDeleteCommand}" />
                        <Button Grid.Column="1" Text="Xóa" Style="{StaticResource DangerBtn}" Command="{Binding ConfirmDeleteCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Popup overlay -->
        <Grid IsVisible="{Binding IsPopupVisible}" BackgroundColor="#70000010" RowSpan="2">
            <Border Style="{StaticResource CardStyle}"
                    VerticalOptions="Center" HorizontalOptions="Center"
                    Padding="16" WidthRequest="320">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding PopupTitle}" TextColor="#F1F1F5" FontAttributes="Bold" />
                    <Label Text="{Binding PopupMessage}" Style="{StaticResource MutedLabel}" />
                    <Button Text="{Binding PopupButtonText}" Style="{StaticResource AccentBtn}"
                            IsVisible="{Binding IsPopupRetry}"
                            Command="{Binding RetryLoadCommand}" />
                    <Button Text="Đóng" Style="{StaticResource GhostBtn}"
                            IsVisible="{Binding IsPopupNotRetry}"
                            Command="{Binding ClosePopupCommand}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
