<?xml version="1.0" encoding="utf-8" ?>
<!--
    SuppliersPage.xaml — Minimal / Modern Dark  (same palette as CustomersPage / VehiclesPage)
    ──────────────────────────────────────────────────────────────────────────
    Palette:
      Background    #0A0A0F    Surface  #111118    Surface2  #1A1A24
      Border        #2A2A38    Accent   #6366F1    Text      #F1F1F5
      Muted         #6B6B80    Danger   #EF4444    Success   #22C55E
-->
<ContentPage
    x:Class="AutoX.Gara.Frontend.Views.SuppliersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:AutoX.Gara.Frontend.ViewModels"
    xmlns:conv="clr-namespace:AutoX.Gara.Frontend.Converters"
    xmlns:enums="clr-namespace:AutoX.Gara.Domain.Enums;assembly=AutoX.Gara.Domain"
    xmlns:dto="clr-namespace:AutoX.Gara.Shared.Protocol.Suppliers;assembly=AutoX.Gara.Shared"
    BackgroundColor="#0A0A0F"
    Title="Quản lý nhà cung cấp">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:InverseBoolConverter           x:Key="InverseBool"   />
            <conv:StringNotEmptyConverter        x:Key="NotEmpty"      />
            <conv:DateTimeToShortStringConverter x:Key="ToShortDate"   />
            <conv:DateNullableConverter x:Key="DateNullableConverter"/>
            
            <!-- ── Colors ── -->
            <Color x:Key="BgColor">#0A0A0F</Color>
            <Color x:Key="SurfaceColor">#111118</Color>
            <Color x:Key="Surface2Color">#1A1A24</Color>
            <Color x:Key="BorderColor">#2A2A38</Color>
            <Color x:Key="AccentColor">#6366F1</Color>
            <Color x:Key="TextColor">#F1F1F5</Color>
            <Color x:Key="MutedColor">#6B6B80</Color>
            <Color x:Key="DangerColor">#EF4444</Color>
            <Color x:Key="SuccessColor">#22C55E</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>

            <!-- ── Styles ── -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="#111118"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Stroke" Value="#2A2A38"/>
                <Setter Property="StrokeShape" Value="RoundRectangle 12"/>
            </Style>

            <Style x:Key="InputStyle" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="#1A1A24"/>
                <Setter Property="TextColor" Value="#F1F1F5"/>
                <Setter Property="PlaceholderColor" Value="#6B6B80"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HeightRequest" Value="44"/>
            </Style>

            <Style x:Key="EditorStyle" TargetType="Editor">
                <Setter Property="BackgroundColor" Value="#1A1A24"/>
                <Setter Property="TextColor" Value="#F1F1F5"/>
                <Setter Property="PlaceholderColor" Value="#6B6B80"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style x:Key="PickerStyle" TargetType="Picker">
                <Setter Property="BackgroundColor" Value="#1A1A24"/>
                <Setter Property="TextColor" Value="#F1F1F5"/>
                <Setter Property="TitleColor" Value="#6B6B80"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="HeightRequest" Value="44"/>
            </Style>

            <Style x:Key="LabelMuted" TargetType="Label">
                <Setter Property="TextColor" Value="#6B6B80"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style x:Key="LabelCaption" TargetType="Label">
                <Setter Property="TextColor" Value="#6B6B80"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="0.8"/>
            </Style>

            <Style x:Key="AccentBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#6366F1"/>
                <Setter Property="TextColor" Value="#F1F1F5"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="HeightRequest" Value="44"/>
                <Setter Property="Padding" Value="20,0"/>
            </Style>

            <Style x:Key="GhostBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="TextColor" Value="#6B6B80"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="HeightRequest" Value="36"/>
                <Setter Property="BorderColor" Value="#2A2A38"/>
                <Setter Property="BorderWidth" Value="1"/>
            </Style>

            <Style x:Key="DangerBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="TextColor" Value="#EF4444"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="HeightRequest" Value="36"/>
                <Setter Property="BorderColor" Value="#EF4444"/>
                <Setter Property="BorderWidth" Value="1"/>
            </Style>

            <!-- Status badge converters handled inline via triggers -->
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Root Grid duy nhất — ContentPage chỉ cho phép 1 Content -->
    <Grid>

        <!-- ── Main layout ── -->
        <Grid RowDefinitions="Auto,*" RowSpacing="0">

            <!-- ══════════════════════════════════════════════════════════════
             ROW 0 — TOP BAR
        ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                BackgroundColor="#111118"
                StrokeThickness="0"
                Padding="20,14,20,14">
                <Border.StrokeShape>
                    <RoundRectangle/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">

                    <!-- Title + breadcrumb -->
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <Label Text="SUPPLIERS"
                           TextColor="#F1F1F5"
                           FontSize="18"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"/>
                        <Label Style="{StaticResource LabelMuted}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding TotalCount, StringFormat='{0} nhà cung cấp'}"
                                      TextColor="#6B6B80" FontSize="12"/>
                                    <Span Text=" · " TextColor="#2A2A38" FontSize="12"/>
                                    <Span Text="{Binding CurrentPage, StringFormat='Trang {0}'}"
                                      TextColor="#6B6B80" FontSize="12"/>
                                    <Span Text="{Binding TotalPages, StringFormat='/{0}'}"
                                      TextColor="#6B6B80" FontSize="12"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>

                    <!-- Add button -->
                    <Button Grid.Column="1"
                        Text="+ Thêm"
                        Style="{StaticResource AccentBtn}"
                        HeightRequest="40"
                        Command="{Binding OpenCreateFormCommand}"/>
                </Grid>
            </Border>

            <!-- Accent line -->
            <BoxView Grid.Row="0"
                 HeightRequest="1"
                 BackgroundColor="#2A2A38"
                 VerticalOptions="End"/>

            <!-- ══════════════════════════════════════════════════════════════
             ROW 1 — MAIN CONTENT
        ══════════════════════════════════════════════════════════════ -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="20,16" Spacing="14">

                    <!-- ── Search + Filter bar ────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}" Padding="14">
                        <Grid RowDefinitions="Auto,Auto" RowSpacing="12">

                            <!-- Search row -->
                            <Grid Grid.Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">

                                <Border Grid.Column="0"
                                    BackgroundColor="#1A1A24"
                                    StrokeThickness="1"
                                    Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="12,0">
                                        <Label Grid.Column="0"
                                           Text="&#x1F50D;"
                                           FontSize="14"
                                           TextColor="#6B6B80"
                                           VerticalOptions="Center"/>
                                        <Entry Grid.Column="1"
                                           Text="{Binding SearchTerm}"
                                           Placeholder="Tìm theo tên, email, MST..."
                                           Style="{StaticResource InputStyle}"
                                           BackgroundColor="Transparent"
                                           Margin="8,0,0,0"/>
                                        <Button Grid.Column="2"
                                            Text="✕"
                                            TextColor="#6B6B80"
                                            BackgroundColor="Transparent"
                                            FontSize="13"
                                            HeightRequest="44"
                                            WidthRequest="36"
                                            Padding="0"
                                            IsVisible="{Binding SearchTerm, Converter={StaticResource StringNotEmptyConverter}}"
                                            Command="{Binding ClearSearchCommand}"/>
                                    </Grid>
                                </Border>

                                <!-- Filter toggle badge -->
                                <Border Grid.Column="1"
                                    BackgroundColor="{Binding HasActiveFilters, Converter={StaticResource BoolToAccentConverter}}"
                                    StrokeThickness="1"
                                    Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="14,0"
                                    HeightRequest="44"
                                    WidthRequest="48">
                                    <Label Text="⚡"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                                </Border>
                            </Grid>

                            <!-- Filter pickers row -->
                            <Grid Grid.Row="1"
                                  HeightRequest="80"
                                  ColumnDefinitions="*,*,Auto"
                                  ColumnSpacing="10">

                                <!-- Filter Status -->
                                <Border Grid.Column="0"
                                    BackgroundColor="#1A1A24"
                                    StrokeThickness="1"
                                    Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8">
                                    <Picker Title="Trạng thái"
                                            HeightRequest="80"
                                            Style="{StaticResource PickerStyle}"
                                            SelectedIndex="{Binding PickerFilterStatusIndex}"
                                            BackgroundColor="Transparent">
                                        <Picker.Items>
                                            <x:String>Tất cả</x:String>
                                            <x:String>Đang hợp tác</x:String>
                                            <x:String>Ngừng hợp tác</x:String>
                                            <x:String>Đối tác tiềm năng</x:String>
                                            <x:String>Tạm dừng hợp tác</x:String>
                                            <x:String>Đang xem xét</x:String>
                                            <x:String>Đã ký hợp đồng</x:String>
                                            <x:String>Bị loại khỏi hệ thống</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>

                                <!-- Filter PaymentTerms -->
                                <Border Grid.Column="1"
                                    BackgroundColor="#1A1A24"
                                    StrokeThickness="1"
                                    Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8">
                                    <Picker Title="Điều khoản TT"
                                            HeightRequest="80"
                                            Style="{StaticResource PickerStyle}"
                                            SelectedIndex="{Binding PickerPaymentTermsIndex}"
                                            BackgroundColor="Transparent">
                                        <Picker.Items>
                                            <x:String>Tất cả</x:String>
                                            <x:String>Thanh toán ngay</x:String>
                                            <x:String>Net 7 ngày</x:String>
                                            <x:String>Net 15 ngày</x:String>
                                            <x:String>Net 30 ngày</x:String>
                                            <x:String>Thỏa thuận riêng</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>

                                <!-- Clear filters -->
                                <Button Grid.Column="2"
                                    Text="Xóa lọc"
                                    Style="{StaticResource GhostBtn}"
                                    IsVisible="{Binding HasActiveFilters}"
                                    WidthRequest="80"
                                    Command="{Binding ClearFiltersCommand}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── Sort header bar ─────────────────────────────────── -->
                    <Grid ColumnDefinitions="*,110,90,70"
                      ColumnSpacing="0"
                      Padding="16,0">
                        <Button Grid.Column="0" Text="Tên ↕"
                            BackgroundColor="Transparent"
                            TextColor="#6B6B80" FontSize="11"
                            FontAttributes="Bold" CharacterSpacing="0.5"
                            HorizontalOptions="Start" Padding="0"
                            HeightRequest="28"
                            Command="{Binding SortByColumnCommand}"
                            CommandParameter="Name"/>
                        <Button Grid.Column="1" Text="Điều khoản ↕"
                            BackgroundColor="Transparent"
                            TextColor="#6B6B80" FontSize="11"
                            FontAttributes="Bold" CharacterSpacing="0.5"
                            HorizontalOptions="Start" Padding="0"
                            HeightRequest="28"
                            Command="{Binding SortByColumnCommand}"
                            CommandParameter="PaymentTerms"/>
                        <Label Grid.Column="2" Text="TRẠNG THÁI"
                           Style="{StaticResource LabelCaption}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                        <Label Grid.Column="3" Text="ACTION"
                           Style="{StaticResource LabelCaption}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Grid>

                    <!-- ── Loading indicator ─────────────────────────────────── -->
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#6366F1"
                                   HeightRequest="40"/>

                    <!-- ── Empty state ────────────────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}"
                        Padding="40,36"
                        IsVisible="{Binding IsEmpty}">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                            <Label Text="📦"
                               FontSize="40"
                               HorizontalOptions="Center"/>
                            <Label Text="Chưa có nhà cung cấp nào"
                               TextColor="#6B6B80"
                               FontSize="15"
                               HorizontalOptions="Center"/>
                            <Label Text="Nhấn &quot;+ Thêm&quot; để tạo nhà cung cấp đầu tiên"
                               TextColor="#6B6B80"
                               FontSize="12"
                               HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Error banner ──────────────────────────────────────── -->
                    <Border StrokeThickness="1"
                        Stroke="#EF4444"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="#1F0F0F"
                        Padding="16,12"
                        IsVisible="{Binding HasError}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0"
                               Text="{Binding ErrorMessage}"
                               TextColor="#EF4444"
                               FontSize="13"
                               VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                Text="Thử lại"
                                TextColor="#6366F1"
                                BackgroundColor="Transparent"
                                FontSize="13"
                                HeightRequest="32"
                                Command="{Binding LoadCommand}"/>
                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════════════════
                     SUPPLIER LIST
                ══════════════════════════════════════════════════════ -->
                    <CollectionView ItemsSource="{Binding Suppliers}"
                                SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="dto:SupplierDto">
                                <Border Style="{StaticResource CardStyle}"
                                    Padding="0">
                                    <Grid ColumnDefinitions="*,110,90,70"
                                      ColumnSpacing="0"
                                      Padding="16,14">

                                        <!-- Col 0: Name + Email + Phones -->
                                        <VerticalStackLayout Grid.Column="0" Spacing="3">
                                            <Label Text="{Binding Name}"
                                               TextColor="#F1F1F5"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Email}"
                                               TextColor="#6B6B80"
                                               FontSize="12"
                                               LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding PhoneNumbers}"
                                               TextColor="#6B6B80"
                                               FontSize="11"
                                               IsVisible="{Binding PhoneNumbers, Converter={StaticResource StringNotEmptyConverter}}"
                                               LineBreakMode="TailTruncation"/>
                                        </VerticalStackLayout>

                                        <!-- Col 1: PaymentTerms + TaxCode -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="3"
                                                         VerticalOptions="Center"
                                                         Padding="8,0">
                                            <Label Text="{Binding PaymentTerms}"
                                               TextColor="#F1F1F5"
                                               FontSize="12"/>
                                            <Label Text="{Binding TaxCode}"
                                               TextColor="#6B6B80"
                                               FontSize="11"
                                               IsVisible="{Binding TaxCode, Converter={StaticResource StringNotEmptyConverter}}"/>
                                        </VerticalStackLayout>

                                        <!-- Col 2: Status badge -->
                                        <Border Grid.Column="2"
                                            StrokeShape="RoundRectangle 6"
                                            StrokeThickness="0"
                                            HeightRequest="26"
                                            WidthRequest="80"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                         Binding="{Binding Status}"
                                                         Value="Active">
                                                    <Setter Property="BackgroundColor" Value="#0A2A14"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border"
                                                         Binding="{Binding Status}"
                                                         Value="Inactive">
                                                    <Setter Property="BackgroundColor" Value="#1A1A24"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border"
                                                         Binding="{Binding Status}"
                                                         Value="Suspended">
                                                    <Setter Property="BackgroundColor" Value="#2A1A0A"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border"
                                                         Binding="{Binding Status}"
                                                         Value="Blacklisted">
                                                    <Setter Property="BackgroundColor" Value="#2A0A0A"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Status}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding Status}"
                                                             Value="Active">
                                                        <Setter Property="TextColor" Value="#22C55E"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding Status}"
                                                             Value="Inactive">
                                                        <Setter Property="TextColor" Value="#6B6B80"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding Status}"
                                                             Value="Suspended">
                                                        <Setter Property="TextColor" Value="#F59E0B"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label"
                                                             Binding="{Binding Status}"
                                                             Value="Blacklisted">
                                                        <Setter Property="TextColor" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>

                                        <!-- Col 3: Action buttons (Edit + ChangeStatus) -->
                                        <HorizontalStackLayout Grid.Column="3"
                                                           Spacing="6"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                            <!-- Edit -->
                                            <Border BackgroundColor="#1A1A24"
                                                StrokeThickness="1"
                                                Stroke="#2A2A38"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,6">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SuppliersViewModel}}, Path=OpenEditFormCommand}"
                                                    CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="✏️" FontSize="13"/>
                                            </Border>

                                            <!-- Change Status -->
                                            <Border BackgroundColor="#1A0A0A"
                                                StrokeThickness="1"
                                                Stroke="#2A1A1A"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,6">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SuppliersViewModel}}, Path=RequestChangeStatusCommand}"
                                                    CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="⚡" FontSize="13"/>
                                            </Border>
                                        </HorizontalStackLayout>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- ── Pagination ─────────────────────────────────────── -->
                    <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="12"
                      Padding="0,4"
                      IsVisible="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}">

                        <Button Grid.Column="0"
                            Text="← Trước"
                            Style="{StaticResource GhostBtn}"
                            WidthRequest="90"
                            IsEnabled="{Binding HasPreviousPage}"
                            Command="{Binding PreviousPageCommand}"/>

                        <Label Grid.Column="1"
                           HorizontalOptions="Center"
                           VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding CurrentPage}"
                                      TextColor="#F1F1F5" FontSize="14" FontAttributes="Bold"/>
                                    <Span Text=" / " TextColor="#6B6B80" FontSize="14"/>
                                    <Span Text="{Binding TotalPages}"
                                      TextColor="#6B6B80" FontSize="14"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Button Grid.Column="2"
                            Text="Tiếp →"
                            Style="{StaticResource GhostBtn}"
                            WidthRequest="90"
                            IsEnabled="{Binding HasNextPage}"
                            Command="{Binding NextPageCommand}"/>
                    </Grid>

                    <BoxView HeightRequest="32" BackgroundColor="Transparent"/>

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════════
         OVERLAY: CREATE / EDIT FORM
    ══════════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsFormVisible}"
          BackgroundColor="#80000000"
          ZIndex="10">

            <Border BackgroundColor="#111118"
                StrokeThickness="1"
                Stroke="#2A2A38"
                StrokeShape="RoundRectangle 16"
                Margin="20,40"
                Padding="24,20">

                <ScrollView>
                    <VerticalStackLayout Spacing="16">

                        <!-- Form header -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                               Text="{Binding FormTitle}"
                               TextColor="#F1F1F5"
                               FontSize="18"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                            <Button Grid.Column="1"
                                Text="✕"
                                TextColor="#6B6B80"
                                BackgroundColor="Transparent"
                                FontSize="18"
                                HeightRequest="36"
                                WidthRequest="36"
                                Padding="0"
                                Command="{Binding CloseFormCommand}"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#2A2A38"/>

                        <!-- Form error -->
                        <Border StrokeThickness="1"
                            Stroke="#EF4444"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="#1F0F0F"
                            Padding="12,10"
                            IsVisible="{Binding HasFormError}">
                            <Label Text="{Binding FormErrorMessage}"
                               TextColor="#EF4444"
                               FontSize="13"/>
                        </Border>

                        <!-- Tên nhà cung cấp -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="TÊN NHÀ CUNG CẤP *"
                               Style="{StaticResource LabelCaption}"/>
                            <Border BackgroundColor="#1A1A24"
                                StrokeThickness="1" Stroke="#2A2A38"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,0">
                                <Entry Text="{Binding FormName}"
                                   Placeholder="Tên công ty / cá nhân"
                                   Style="{StaticResource InputStyle}"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="EMAIL *" Style="{StaticResource LabelCaption}"/>
                            <Border BackgroundColor="#1A1A24"
                                StrokeThickness="1" Stroke="#2A2A38"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,0">
                                <Entry Text="{Binding FormEmail}"
                                   Placeholder="supplier@example.com"
                                   Keyboard="Email"
                                   Style="{StaticResource InputStyle}"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- MST + Tài khoản ngân hàng -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="MÃ SỐ THUẾ *" Style="{StaticResource LabelCaption}"/>
                                <Border BackgroundColor="#1A1A24"
                                    StrokeThickness="1" Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12,0">
                                    <Entry Text="{Binding FormTaxCode}"
                                       Placeholder="0123456789"
                                       Keyboard="Numeric"
                                       Style="{StaticResource InputStyle}"
                                       BackgroundColor="Transparent"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="TÀI KHOẢN NH" Style="{StaticResource LabelCaption}"/>
                                <Border BackgroundColor="#1A1A24"
                                    StrokeThickness="1" Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12,0">
                                    <Entry Text="{Binding FormBankAccount}"
                                       Placeholder="0001 2345 6789"
                                       Keyboard="Numeric"
                                       Style="{StaticResource InputStyle}"
                                       BackgroundColor="Transparent"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Địa chỉ -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="ĐỊA CHỈ" Style="{StaticResource LabelCaption}"/>
                            <Border BackgroundColor="#1A1A24"
                                StrokeThickness="1" Stroke="#2A2A38"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,0">
                                <Entry Text="{Binding FormAddress}"
                                   Placeholder="Số nhà, đường, quận, tỉnh..."
                                   Style="{StaticResource InputStyle}"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- SĐT (CSV) -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="SỐ ĐIỆN THOẠI" Style="{StaticResource LabelCaption}"/>
                            <Label Text="Nhiều số: phân cách bằng dấu phẩy — VD: 0901234567,0912345678"
                               TextColor="#6B6B80" FontSize="11"/>
                            <Border BackgroundColor="#1A1A24"
                                StrokeThickness="1" Stroke="#2A2A38"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,0">
                                <Entry Text="{Binding FormPhoneNumbers}"
                                   Placeholder="0901234567"
                                   Keyboard="Telephone"
                                   Style="{StaticResource InputStyle}"
                                   BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Trạng thái + Điều khoản TT -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="TRẠNG THÁI" Style="{StaticResource LabelCaption}"/>
                                <Border BackgroundColor="#1A1A24"
                                    StrokeThickness="1" Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8">
                                    <Picker Title="Chọn trạng thái"
                                            HeightRequest="80"
                                            Style="{StaticResource PickerStyle}"
                                            SelectedIndex="{Binding FormPickerStatusIndex}"
                                            BackgroundColor="Transparent">
                                        <Picker.Items>
                                            <x:String>Không xác định</x:String>
                                            <x:String>Đang hợp tác</x:String>
                                            <x:String>Ngừng hợp tác</x:String>
                                            <x:String>Đối tác tiềm năng</x:String>
                                            <x:String>Tạm dừng hợp tác</x:String>
                                            <x:String>Đang xem xét</x:String>
                                            <x:String>Đã ký hợp đồng</x:String>
                                            <x:String>Bị loại khỏi hệ thống</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="ĐIỀU KHOẢN THANH TOÁN" Style="{StaticResource LabelCaption}"/>
                                <Border BackgroundColor="#1A1A24"
                                    StrokeThickness="1" Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8">
                                    <Picker Title="Chọn điều khoản"
                                            HeightRequest="80"
                                            Style="{StaticResource PickerStyle}"
                                            SelectedIndex="{Binding FormPickerPaymentTermsIndex}"
                                            BackgroundColor="Transparent">
                                        <Picker.Items>
                                            <x:String>Không xác định</x:String>
                                            <x:String>Thanh toán ngay</x:String>
                                            <x:String>Net 7 ngày</x:String>
                                            <x:String>Net 15 ngày</x:String>
                                            <x:String>Net 30 ngày</x:String>
                                            <x:String>Thỏa thuận riêng</x:String>
                                        </Picker.Items>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Ngày bắt đầu + kết thúc hợp đồng -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                <Label Text="NGÀY BẮT ĐẦU HĐ" Style="{StaticResource LabelCaption}"/>
                                <Border BackgroundColor="#1A1A24"
                                    StrokeThickness="1" Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12,0">
                                    <DatePicker Date="{Binding FormContractStartDate}"
                                            Format="dd/MM/yyyy"
                                            TextColor="#F1F1F5"
                                            BackgroundColor="Transparent"
                                            HeightRequest="44"/>
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" Spacing="6">
                                <Label Text="NGÀY KẾT THÚC HĐ" Style="{StaticResource LabelCaption}"/>
                                <Border BackgroundColor="#1A1A24"
                                    StrokeThickness="1" Stroke="#2A2A38"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12,0">
                                    <DatePicker Date="{Binding FormContractEndDate}"
                                            Format="dd/MM/yyyy"
                                            TextColor="#F1F1F5"
                                            BackgroundColor="Transparent"
                                            HeightRequest="44"/>
                                </Border>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Ghi chú -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="GHI CHÚ" Style="{StaticResource LabelCaption}"/>
                            <Border BackgroundColor="#1A1A24"
                                StrokeThickness="1" Stroke="#2A2A38"
                                StrokeShape="RoundRectangle 8"
                                Padding="12,8">
                                <Editor Text="{Binding FormNotes}"
                                    Placeholder="Ghi chú nội bộ (tối đa 500 ký tự)"
                                    Style="{StaticResource EditorStyle}"
                                    BackgroundColor="Transparent"
                                    HeightRequest="80"
                                    MaxLength="500"/>
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="4" BackgroundColor="Transparent"/>

                        <!-- Action buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Button Grid.Column="0"
                                Text="Hủy"
                                Style="{StaticResource GhostBtn}"
                                HeightRequest="44"
                                Command="{Binding CloseFormCommand}"/>
                            <Button Grid.Column="1"
                                Text="{Binding FormSaveText}"
                                Style="{StaticResource AccentBtn}"
                                HeightRequest="44"
                                Command="{Binding SaveFormCommand}"/>
                        </Grid>

                        <BoxView HeightRequest="8" BackgroundColor="Transparent"/>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════════
         OVERLAY: CHANGE STATUS CONFIRM  (SUPERVISOR only)
    ══════════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsChangeStatusVisible}"
          BackgroundColor="#80000000"
          ZIndex="20">
            <Border BackgroundColor="#111118"
                StrokeThickness="1"
                Stroke="#2A2A38"
                StrokeShape="RoundRectangle 16"
                Margin="32,0"
                VerticalOptions="Center"
                Padding="28,24">
                <VerticalStackLayout Spacing="16">

                    <!-- Icon -->
                    <Label Text="⚡"
                       FontSize="36"
                       HorizontalOptions="Center"/>

                    <!-- Title -->
                    <Label Text="Đổi trạng thái"
                       TextColor="#F1F1F5"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                    <!-- Message -->
                    <Label Text="{Binding ChangeStatusConfirmMessage}"
                       TextColor="#6B6B80"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>

                    <!-- Pending status badge -->
                    <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 8"
                        Padding="16,8"
                        HorizontalOptions="Center">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                     Binding="{Binding PendingStatus}"
                                     Value="Active">
                                <Setter Property="BackgroundColor" Value="#0A2A14"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border"
                                     Binding="{Binding PendingStatus}"
                                     Value="Suspended">
                                <Setter Property="BackgroundColor" Value="#2A1A0A"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border"
                                     Binding="{Binding PendingStatus}"
                                     Value="Inactive">
                                <Setter Property="BackgroundColor" Value="#1A1A24"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border"
                                     Binding="{Binding PendingStatus}"
                                     Value="Blacklisted">
                                <Setter Property="BackgroundColor" Value="#2A0A0A"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="{Binding PendingStatus}"
                           FontAttributes="Bold"
                           FontSize="14">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                         Binding="{Binding PendingStatus}"
                                         Value="Active">
                                    <Setter Property="TextColor" Value="#22C55E"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                         Binding="{Binding PendingStatus}"
                                         Value="Suspended">
                                    <Setter Property="TextColor" Value="#F59E0B"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                         Binding="{Binding PendingStatus}"
                                         Value="Inactive">
                                    <Setter Property="TextColor" Value="#6B6B80"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                         Binding="{Binding PendingStatus}"
                                         Value="Blacklisted">
                                    <Setter Property="TextColor" Value="#EF4444"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <BoxView HeightRequest="4" BackgroundColor="Transparent"/>

                    <!-- Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0"
                            Text="Hủy"
                            Style="{StaticResource GhostBtn}"
                            HeightRequest="44"
                            Command="{Binding CancelChangeStatusCommand}"/>
                        <Button Grid.Column="1"
                            Text="Xác nhận"
                            Style="{StaticResource AccentBtn}"
                            HeightRequest="44"
                            Command="{Binding ConfirmChangeStatusCommand}"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════════════
         OVERLAY: ERROR POPUP
    ══════════════════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsPopupVisible}"
          BackgroundColor="#80000000"
          ZIndex="30">
            <Border BackgroundColor="#111118"
                StrokeThickness="1"
                Stroke="#2A2A38"
                StrokeShape="RoundRectangle 16"
                Margin="32,0"
                VerticalOptions="Center"
                Padding="28,24">
                <VerticalStackLayout Spacing="14">

                    <Label Text="{Binding PopupTitle}"
                       TextColor="#F1F1F5"
                       FontSize="16"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                    <Label Text="{Binding PopupMessage}"
                       TextColor="#6B6B80"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Center"/>

                    <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      IsVisible="{Binding IsPopupRetry}">
                        <Button Grid.Column="0"
                            Text="Đóng"
                            Style="{StaticResource GhostBtn}"
                            HeightRequest="44"
                            Command="{Binding ClosePopupCommand}"/>
                        <Button Grid.Column="1"
                            Text="Thử lại"
                            Style="{StaticResource AccentBtn}"
                            HeightRequest="44"
                            Command="{Binding RetryLoadCommand}"/>
                    </Grid>

                    <Button Text="{Binding PopupButtonText}"
                        Style="{StaticResource AccentBtn}"
                        HeightRequest="44"
                        IsVisible="{Binding IsPopupNotRetry}"
                        Command="{Binding ClosePopupCommand}"/>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- /Root Grid -->
    </Grid>

</ContentPage>
