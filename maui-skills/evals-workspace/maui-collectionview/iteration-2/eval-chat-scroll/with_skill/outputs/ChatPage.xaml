<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ChatApp.Models"
             xmlns:viewmodels="clr-namespace:ChatApp.ViewModels"
             x:Class="ChatApp.Views.ChatPage"
             x:DataType="viewmodels:ChatViewModel"
             Title="Chat">

    <Shell.TitleView>
        <Label Text="Alice"
               FontAttributes="Bold"
               FontSize="18"
               HorizontalOptions="Center"
               VerticalOptions="Center" />
    </Shell.TitleView>

    <Grid RowDefinitions="*, Auto"
          BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1C1C1E}">

        <!-- Message list -->
        <CollectionView x:Name="MessagesCollectionView"
                        Grid.Row="0"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="None"
                        Margin="0,8,0,0">

            <CollectionView.ItemsLayout>
                <!-- MeasureAllItems used because chat bubbles vary in height -->
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="4" />
            </CollectionView.ItemsLayout>

            <CollectionView.EmptyView>
                <ContentView>
                    <Label Text="No messages yet. Say hello!"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           TextColor="Gray"
                           Margin="0,40,0,0" />
                </ContentView>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Message">
                    <!--
                        Outer Grid fills the full row width so HorizontalOptions on the
                        bubble StackLayout correctly right-aligns or left-aligns within it.
                    -->
                    <Grid Padding="12,2">

                        <!-- Message bubble -->
                        <VerticalStackLayout HorizontalOptions="{Binding HorizontalAlignment}"
                                             MaximumWidthRequest="280"
                                             Spacing="2">

                            <!-- Sender name — only shown for incoming messages -->
                            <Label Text="{Binding SenderName}"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="Gray"
                                   IsVisible="{Binding IsFromMe, Converter={StaticResource InvertBoolConverter}}"
                                   Margin="4,0,0,0" />

                            <!-- Bubble -->
                            <Border BackgroundColor="{Binding BubbleColor}"
                                    StrokeThickness="0"
                                    Padding="12,8">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Text}"
                                           TextColor="{Binding TextColor}"
                                           FontSize="15"
                                           LineBreakMode="WordWrap" />

                                    <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}"
                                           FontSize="10"
                                           TextColor="{Binding TextColor}"
                                           Opacity="0.7"
                                           HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Input bar -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2C2C2E}"
                StrokeThickness="0"
                Padding="8">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Offset="0,-2" Radius="4" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*, Auto"
                  ColumnSpacing="8">

                <Border Grid.Column="0"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#DDDDDD, Dark=#555555}"
                        Padding="12,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Entry x:Name="MessageEntry"
                           Text="{Binding InputText}"
                           Placeholder="Type a message…"
                           ReturnType="Send"
                           ReturnCommand="{Binding SendCommand}"
                           VerticalOptions="Center" />
                </Border>

                <Button Grid.Column="1"
                        Text="Send"
                        Command="{Binding SendCommand}"
                        CornerRadius="20"
                        WidthRequest="72"
                        BackgroundColor="#0078D4"
                        TextColor="White" />

            </Grid>
        </Border>

    </Grid>

</ContentPage>
