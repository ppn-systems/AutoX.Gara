<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="EcommerceCatalog.Views.CatalogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:EcommerceCatalog.Models"
    xmlns:vm="clr-namespace:EcommerceCatalog.ViewModels"
    x:DataType="vm:CatalogViewModel"
    Title="Product Catalog">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Reusable styles -->
            <Style x:Key="CategoryHeaderStyle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#1A1A2E, Dark=#E0E0E0}" />
            </Style>

            <Style x:Key="ItemCountStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#555555, Dark=#AAAAAA}" />
            </Style>

            <Style x:Key="ProductNameStyle" TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="LineBreakMode" Value="TailTruncation" />
            </Style>

            <Style x:Key="PriceStyle" TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
            </Style>

            <Style x:Key="AddToCartButtonStyle" TargetType="Button">
                <Setter Property="Text" Value="Add to Cart" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#1565C0, Dark=#42A5F5}" />
                <Setter Property="TextColor" Value="White" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!--
        RefreshView wraps the CollectionView to provide pull-to-refresh.
        IsRefreshing is two-way so the view model can set it to false when done.
        Command fires LoadProductsAsync via RefreshCommand.
    -->
    <RefreshView
        Command="{Binding RefreshCommand}"
        IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}">

        <CollectionView
            ItemsSource="{Binding ProductGroups}"
            IsGrouped="True"
            SelectionMode="None">

            <!-- ================================================================
                 Group header template — shown once per ProductGroup.
                 x:DataType targets ProductGroup for compiled bindings.
                 ================================================================ -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:ProductGroup">
                    <Grid
                        Padding="16,12,16,6"
                        ColumnDefinitions="*,Auto"
                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E2E}">

                        <Label
                            Grid.Column="0"
                            Text="{Binding CategoryName}"
                            Style="{StaticResource CategoryHeaderStyle}"
                            VerticalOptions="Center" />

                        <Label
                            Grid.Column="1"
                            Text="{Binding ItemCount, StringFormat='{0} item(s)'}"
                            Style="{StaticResource ItemCountStyle}"
                            VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- ================================================================
                 Item template — one card per Product.
                 x:DataType targets Product for compiled bindings.
                 ================================================================ -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Product">
                    <Border
                        Margin="12,4"
                        Padding="14,12"
                        StrokeShape="RoundRectangle 10"
                        Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333355}"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A3E}">

                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">

                            <!-- Product name -->
                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                Text="{Binding Name}"
                                Style="{StaticResource ProductNameStyle}"
                                VerticalOptions="Center" />

                            <!-- Add to Cart button.
                                 CommandParameter passes the bound Product instance up to the
                                 ViewModel. We must reach out of the DataTemplate scope to the
                                 page's BindingContext (the ViewModel) using Source + x:Reference. -->
                            <Button
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                Style="{StaticResource AddToCartButtonStyle}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CatalogViewModel}}, Path=AddToCartCommand}"
                                CommandParameter="{Binding .}"
                                VerticalOptions="Center" />

                            <!-- Price formatted as local currency -->
                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                Text="{Binding Price, StringFormat='{0:C}'}"
                                Style="{StaticResource PriceStyle}"
                                VerticalOptions="End" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- ================================================================
                 EmptyView — displayed when ProductGroups is empty.
                 ================================================================ -->
            <CollectionView.EmptyView>
                <VerticalStackLayout
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Spacing="12"
                    Padding="32">

                    <Image
                        Source="empty_catalog.png"
                        HeightRequest="120"
                        Opacity="0.5"
                        HorizontalOptions="Center"
                        IsVisible="False" />

                    <Label
                        Text="No products found"
                        FontSize="20"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />

                    <Label
                        Text="Pull down to refresh and check again."
                        FontSize="14"
                        HorizontalTextAlignment="Center"
                        TextColor="{AppThemeBinding Light=#777777, Dark=#999999}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

        </CollectionView>
    </RefreshView>

</ContentPage>
